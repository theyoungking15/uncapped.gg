<script>
  (() => {
    const currentScript = document.currentScript;
    const section =
      (currentScript && typeof currentScript.closest === "function"
        ? currentScript.closest("[data-my-builds-section]")
        : null) || document.querySelector("[data-my-builds-section]");
    if (!section) return;

    const statusEl = section.querySelector("[data-my-builds-status]");
    const authEl = section.querySelector("[data-my-builds-auth]");
    const errorEl = section.querySelector("[data-my-builds-error]");
    const errorTextEl = section.querySelector("[data-my-builds-error-text]");
    const emptyEl = section.querySelector("[data-my-builds-empty]");
    const resultsEl = section.querySelector("[data-my-builds-results]");
    const flashEl = section.querySelector("[data-my-builds-flash]");
    const countEl = section.querySelector("[data-my-builds-count]");
    const listCountEl = section.querySelector("[data-my-builds-list-count]");
    const listEl = section.querySelector("[data-my-builds-list]");
    const detailEmptyEl = section.querySelector("[data-build-detail-empty]");
    const detailContentEl = section.querySelector("[data-build-detail-content]");
    const componentsEl = section.querySelector("[data-detail-components]");
    const retryButton = section.querySelector("[data-my-builds-retry]");
    const listTemplate = section.querySelector("[data-my-builds-list-template]");
    const itemTemplate = section.querySelector("[data-my-builds-item-template]");
    const builderUrl = String(section.getAttribute("data-builder-url") || "").trim() || "/pages/pc-builder-2";
    const proxyBase = String(section.getAttribute("data-proxy-base") || "").replace(/\/+$/, "");
    const listEndpoint = String(section.getAttribute("data-list-endpoint") || "").replace(/\/+$/, "");
    const allowedScreenshotModes = new Set([
      "detailed",
      "clean",
      "compact",
      "compact_mobile",
      "socials_compact",
      "socials_compact_mobile",
      "quotation",
      "quotation_mobile"
    ]);
    const screenshotModeDesktopRaw = String(section.getAttribute("data-quote-screenshot-mode") || "").trim().toLowerCase();
    const screenshotModeMobileRaw = String(section.getAttribute("data-quote-screenshot-mode-mobile") || "").trim().toLowerCase();
    const screenshotModeDesktop = allowedScreenshotModes.has(screenshotModeDesktopRaw) ? screenshotModeDesktopRaw : "detailed";
    const screenshotModeMobile =
      screenshotModeMobileRaw === "same_as_desktop" || allowedScreenshotModes.has(screenshotModeMobileRaw)
        ? screenshotModeMobileRaw
        : "same_as_desktop";
    const screenshotFontPreset = String(section.getAttribute("data-quote-font-preset") || "inter_roboto").trim();
    const screenshotBrandLogo = String(section.getAttribute("data-screenshot-brand-logo") || "").trim();
    let currentBuilds = [];
    let selectedHandle = "";
    let flashTimer = null;

    if (!listEl || !listTemplate || !itemTemplate) return;

    function hideAllStates() {
      [statusEl, authEl, errorEl, emptyEl, resultsEl].forEach((node) => {
        if (node) node.hidden = true;
      });
    }

    function clearFlash() {
      if (flashTimer) {
        clearTimeout(flashTimer);
        flashTimer = null;
      }
      if (flashEl) {
        flashEl.hidden = true;
        flashEl.classList.remove("mb-page__flash--error", "mb-page__flash--success");
        flashEl.textContent = "";
      }
    }

    function showFlash(message, tone = "success") {
      if (!flashEl) return;
      clearFlash();
      flashEl.textContent = String(message || "").trim();
      if (!flashEl.textContent) return;
      flashEl.classList.add(tone === "error" ? "mb-page__flash--error" : "mb-page__flash--success");
      flashEl.hidden = false;
      flashTimer = setTimeout(clearFlash, 4200);
    }

    function normalizeStatus(value) {
      const normalized = String(value || "").trim().toLowerCase();
      return normalized === "archived" ? "archived" : "active";
    }

    function formatDate(value) {
      const source = String(value || "").trim();
      if (!source) return "-";
      const parsed = new Date(source);
      if (Number.isNaN(parsed.getTime())) return source;
      return new Intl.DateTimeFormat(undefined, {
        year: "numeric",
        month: "short",
        day: "numeric"
      }).format(parsed);
    }

    function formatMoney(value) {
      if (value === null || value === undefined || value === "") return "-";
      const amount = Number(value);
      if (!Number.isFinite(amount)) return "-";
      try {
        return new Intl.NumberFormat("en-PH", {
          style: "currency",
          currency: "PHP",
          maximumFractionDigits: 0
        }).format(amount);
      } catch (error) {
        return `PHP ${Math.round(amount)}`;
      }
    }

    function normId(value) {
      const raw = String(value || "").trim();
      if (!raw) return "";
      if (raw.includes("gid://")) {
        const parts = raw.split("/");
        return parts[parts.length - 1] || raw;
      }
      return raw;
    }

    function getBuildSnapshot(build) {
      return build && build.buildSnapshot && typeof build.buildSnapshot === "object" && !Array.isArray(build.buildSnapshot)
        ? build.buildSnapshot
        : null;
    }

    function getSnapshotItems(build) {
      const snapshot = getBuildSnapshot(build);
      return snapshot && Array.isArray(snapshot.items) ? snapshot.items : [];
    }

    function getItemPrice(item) {
      const effective = Number(item && (item.priceEffective ?? item.price_effective));
      if (Number.isFinite(effective) && effective > 0) return effective;
      const base = Number(item && (item.priceBase ?? item.price_base));
      if (Number.isFinite(base) && base > 0) return base;
      return null;
    }

    function getBuildTotal(build) {
      const snapshot = getBuildSnapshot(build);
      const totals = snapshot && snapshot.totals && typeof snapshot.totals === "object" ? snapshot.totals : {};
      const direct = Number(totals.total ?? totals.payableSubtotal ?? totals.subtotalBase);
      if (Number.isFinite(direct) && direct > 0) return direct;

      const fromItems = getSnapshotItems(build).reduce((sum, item) => {
        const price = getItemPrice(item);
        return Number.isFinite(price) ? sum + price : sum;
      }, 0);
      return fromItems > 0 ? fromItems : null;
    }

    function getSnapshotSubtotalDisplay(build) {
      const snapshot = getBuildSnapshot(build);
      const meta = snapshot && snapshot.meta && typeof snapshot.meta === "object" ? snapshot.meta : {};
      return String(meta.subtotalDisplay || "").trim();
    }

    function getBuildPromoHandle(build) {
      const snapshot = getBuildSnapshot(build);
      const meta = snapshot && snapshot.meta && typeof snapshot.meta === "object" ? snapshot.meta : {};
      return String(meta.promoHandle || meta.promo_handle || "").trim();
    }

    function getBuildQuoteVersion(build) {
      const direct = Number(build && build.quoteVersion);
      if (Number.isFinite(direct) && direct > 0) return direct;
      const snapshot = getBuildSnapshot(build);
      const meta = snapshot && snapshot.meta && typeof snapshot.meta === "object" ? snapshot.meta : {};
      const fallback = Number(meta.quoteVersion || meta.quote_version);
      return Number.isFinite(fallback) && fallback > 0 ? fallback : 0;
    }

    function getBuildManualOff(build) {
      const snapshot = getBuildSnapshot(build);
      const totals = snapshot && snapshot.totals && typeof snapshot.totals === "object" ? snapshot.totals : {};
      const manualOff = Number(totals.manualOff ?? totals.manual_off);
      return Number.isFinite(manualOff) && manualOff > 0 ? Math.round(manualOff) : 0;
    }

    function buildQuoteUrl(build) {
      const quoteCode = String(build && build.quoteCode ? build.quoteCode : "").trim();
      const quoteVersion = getBuildQuoteVersion(build);
      const promoHandle = getBuildPromoHandle(build);
      const manualOff = getBuildManualOff(build);
      if (!quoteCode || !(quoteVersion > 0)) return "";

      try {
        const url = new URL(builderUrl, window.location.origin);
        url.searchParams.delete("build");
        url.searchParams.set("quote", quoteCode);
        url.searchParams.set("v", String(quoteVersion));
        if (promoHandle) url.searchParams.set("promo", promoHandle);
        else url.searchParams.delete("promo");
        if (manualOff > 0) url.searchParams.set("off", String(manualOff));
        else url.searchParams.delete("off");
        return url.toString();
      } catch (error) {
        return "";
      }
    }

    function buildOpenUrl(build) {
      const encoded = String(build && build.buildPayloadEncoded ? build.buildPayloadEncoded : "").trim();
      const promoHandle = getBuildPromoHandle(build);
      const quoteUrl = buildQuoteUrl(build);

      if (quoteUrl) return quoteUrl;

      try {
        const url = new URL(builderUrl, window.location.origin);
        url.searchParams.delete("promo");
        if (encoded) {
          url.searchParams.delete("quote");
          url.searchParams.delete("v");
          url.searchParams.set("build", encoded);
          if (promoHandle) url.searchParams.set("promo", promoHandle);
          return url.toString();
        }

        return "";
      } catch (error) {
        return "";
      }
    }

    function buildTaggedShareUrl(build, sourceTag) {
      const baseUrl = buildOpenUrl(build);
      const normalizedSource = String(sourceTag || "").trim().toLowerCase();
      if (!baseUrl || !normalizedSource) return baseUrl;

      try {
        const url = new URL(baseUrl, window.location.origin);
        url.searchParams.set("src", normalizedSource);
        return url.toString();
      } catch (error) {
        return baseUrl;
      }
    }

    function itemBuyUrl(item) {
      const explicit = String(item && (item.productUrl || item.product_url || item.url) ? item.productUrl || item.product_url || item.url : "").trim();
      if (explicit) {
        try {
          return new URL(explicit, window.location.origin).toString();
        } catch (error) {
          return explicit;
        }
      }

      const handle = String(item && (item.handle || item.productHandle) ? item.handle || item.productHandle : "").trim();
      if (!handle) return "";

      try {
        const url = new URL(`/products/${encodeURIComponent(handle)}`, window.location.origin);
        const variantId = normId(item && (item.variantId || item.variant_id));
        if (variantId) url.searchParams.set("variant", variantId);
        return url.toString();
      } catch (error) {
        return "";
      }
    }

    function buildActionEndpoint(handle, action) {
      const normalizedHandle = String(handle || "").trim();
      const normalizedAction = String(action || "").trim();
      if (!proxyBase || !normalizedHandle || !normalizedAction) return "";
      return `${proxyBase}/my-builds/${encodeURIComponent(normalizedHandle)}/${normalizedAction}`;
    }

    function findBuild(handle) {
      const normalizedHandle = String(handle || "").trim();
      return currentBuilds.find((build) => String(build && build.handle ? build.handle : "").trim() === normalizedHandle) || null;
    }

    function setHandleBusy(handle, isBusy) {
      const normalizedHandle = String(handle || "").trim();
      if (!normalizedHandle) return;
      section.querySelectorAll("button[data-build-action]").forEach((button) => {
        if (String(button.getAttribute("data-build-handle") || "").trim() === normalizedHandle) {
          button.disabled = !!isBusy;
        }
      });
    }

    async function copyToClipboard(text) {
      const value = String(text || "").trim();
      if (!value) return false;

      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(value);
          return true;
        }
      } catch (error) {
      }

      try {
        const input = document.createElement("textarea");
        input.value = value;
        input.setAttribute("readonly", "readonly");
        input.style.position = "fixed";
        input.style.opacity = "0";
        document.body.appendChild(input);
        input.focus();
        input.select();
        const ok = document.execCommand("copy");
        document.body.removeChild(input);
        return !!ok;
      } catch (error) {
        return false;
      }
    }

    async function postBuildAction(handle, action, body = null) {
      const endpoint = buildActionEndpoint(handle, action);
      if (!endpoint) {
        throw new Error("The section is missing a valid build action endpoint.");
      }

      const response = await fetch(endpoint, {
        method: "POST",
        credentials: "same-origin",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json"
        },
        body: body ? JSON.stringify(body) : "{}"
      });

      let data = null;
      try {
        data = await response.json();
      } catch (error) {
        data = null;
      }

      if (!response.ok || !data || !data.ok) {
        throw new Error(
          data && data.error
            ? data.error
            : "The saved-build action returned an unexpected response."
        );
      }

      return data;
    }

    function renderBuildList(builds) {
      listEl.innerHTML = "";
      builds.forEach((build) => {
        const fragment = listTemplate.content.cloneNode(true);
        const button = fragment.querySelector("[data-build-list-item]");
        const handle = String(build && build.handle ? build.handle : "").trim();
        const nameEl = fragment.querySelector("[data-list-build-name]");
        const metaEl = fragment.querySelector("[data-list-build-meta]");
        const status = normalizeStatus(build && build.status);
        const quote = String(build && build.quoteCode ? build.quoteCode : "").trim();
        const updated = formatDate(build && build.updatedAt);

        button.setAttribute("data-build-handle", handle);
        if (handle === selectedHandle) button.classList.add("is-selected");
        nameEl.textContent = String(build && build.buildName ? build.buildName : "Saved build");
        metaEl.textContent = [status === "archived" ? "Archived" : "", quote || "", updated ? `Updated ${updated}` : ""]
          .filter(Boolean)
          .join(" - ");
        listEl.appendChild(fragment);
      });
    }

    function renderComponent(item) {
      const fragment = itemTemplate.content.cloneNode(true);
      const image = fragment.querySelector("[data-component-image]");
      const imageFallback = fragment.querySelector("[data-component-image-fallback]");
      const imageUrl = String(item && item.image ? item.image : "").trim();
      const title = String(item && item.title ? item.title : "Saved component").trim();
      const variant = String(item && (item.variantTitle || item.variant_title) ? item.variantTitle || item.variant_title : "").trim();
      const quick = String(item && (item.quick_description || item.quickDescription) ? item.quick_description || item.quickDescription : "").trim();
      const qty = Number(item && item.qty ? item.qty : 1);
      const safeQty = Number.isFinite(qty) && qty > 0 ? qty : 1;
      const price = getItemPrice(item);
      const buyUrl = itemBuyUrl(item);

      if (imageUrl) {
        image.src = imageUrl;
        image.alt = title;
        image.hidden = false;
        imageFallback.hidden = true;
      } else {
        image.removeAttribute("src");
        image.hidden = true;
        imageFallback.hidden = false;
      }

      fragment.querySelector("[data-component-label]").textContent = String(item && (item.label || item.componentLabel || item.key) ? item.label || item.componentLabel || item.key : "Component");
      fragment.querySelector("[data-component-title]").textContent = title;
      fragment.querySelector("[data-component-qty]").textContent = String(safeQty);
      fragment.querySelector("[data-component-price]").textContent = Number.isFinite(price) ? formatMoney(price) : "-";

      const variantEl = fragment.querySelector("[data-component-variant]");
      if (variant && variant.toLowerCase() !== "default title") {
        variantEl.textContent = variant;
        variantEl.hidden = false;
      }

      const quickEl = fragment.querySelector("[data-component-quick]");
      if (quick) {
        quickEl.textContent = quick;
        quickEl.hidden = false;
      }

      const buyEl = fragment.querySelector("[data-component-buy]");
      if (buyUrl) {
        buyEl.href = buyUrl;
        buyEl.hidden = false;
      }

      return fragment;
    }

    function setDetailActionHandles(handle) {
      section.querySelectorAll(".mb-page__detailActions [data-build-action]").forEach((button) => {
        button.setAttribute("data-build-handle", handle);
      });
    }

    function renderBuildDetail(build) {
      if (!build) {
        if (detailEmptyEl) detailEmptyEl.hidden = false;
        if (detailContentEl) detailContentEl.hidden = true;
        return;
      }

      const handle = String(build.handle || "").trim();
      const status = normalizeStatus(build.status);
      const items = getSnapshotItems(build);
      const summary = String(build.summaryText || "").trim();
      const openUrl = buildOpenUrl(build);
      const total = getBuildTotal(build);
      const subtotalDisplay = getSnapshotSubtotalDisplay(build);

      setDetailActionHandles(handle);
      if (detailEmptyEl) detailEmptyEl.hidden = true;
      if (detailContentEl) detailContentEl.hidden = false;

      section.querySelector("[data-detail-status]").textContent = status;
      section.querySelector("[data-detail-visibility]").textContent = String(build.visibility || "private");
      section.querySelector("[data-detail-name]").textContent = String(build.buildName || "Saved build");
      section.querySelector("[data-detail-updated]").textContent = formatDate(build.updatedAt);
      section.querySelector("[data-detail-created]").textContent = formatDate(build.createdAt);
      section.querySelector("[data-detail-quote]").textContent = String(build.quoteCode || "-");
      section.querySelector("[data-detail-total-items]").textContent = String(Number(build.totalItems) || items.length || 0);
      section.querySelector("[data-detail-component-count]").textContent = items.length === 1 ? "1 component" : `${items.length} components`;
      section.querySelector("[data-detail-total-price]").textContent = Number.isFinite(total) ? formatMoney(total) : (subtotalDisplay || "-");

      const summaryEl = section.querySelector("[data-detail-summary]");
      if (summary) {
        summaryEl.textContent = summary;
        summaryEl.hidden = false;
      } else {
        summaryEl.textContent = "";
        summaryEl.hidden = true;
      }

      const openLink = section.querySelector("[data-detail-open]");
      if (openLink && openUrl) {
        openLink.href = openUrl;
        openLink.hidden = false;
      } else if (openLink) {
        openLink.hidden = true;
      }

      const archiveButton = section.querySelector('.mb-page__detailActions [data-build-action="archive"]');
      const unarchiveButton = section.querySelector('.mb-page__detailActions [data-build-action="unarchive"]');
      const shareButton = section.querySelector('.mb-page__detailActions [data-build-action="share"]');
      const screenshotButton = section.querySelector('.mb-page__detailActions [data-build-action="screenshot"]');

      if (archiveButton) archiveButton.hidden = status !== "active";
      if (unarchiveButton) unarchiveButton.hidden = status === "active";
      if (shareButton) shareButton.hidden = status !== "active";
      if (screenshotButton) screenshotButton.disabled = !items.length;

      const fallbackEl = section.querySelector("[data-detail-fallback]");
      if (fallbackEl) fallbackEl.hidden = items.length > 0;

      componentsEl.innerHTML = "";
      items.forEach((item) => {
        componentsEl.appendChild(renderComponent(item));
      });
    }

    function selectBuild(handle) {
      selectedHandle = String(handle || "").trim();
      const selected = findBuild(selectedHandle);
      renderBuildList(currentBuilds);
      renderBuildDetail(selected);
    }

    function renderBuilds(builds, preferredHandle = "") {
      currentBuilds = builds;
      const preferred = String(preferredHandle || selectedHandle || "").trim();
      const preferredBuild = preferred ? findBuild(preferred) : null;
      const activeBuild = builds.find((build) => normalizeStatus(build && build.status) === "active") || null;
      const selected = preferredBuild || activeBuild || builds[0] || null;
      selectedHandle = selected ? String(selected.handle || "").trim() : "";

      renderBuildList(builds);
      renderBuildDetail(selected);

      if (countEl) {
        countEl.textContent = builds.length === 1 ? "1 saved build loaded" : `${builds.length} saved builds loaded`;
      }
      if (listCountEl) {
        const activeCount = builds.filter((build) => normalizeStatus(build && build.status) === "active").length;
        const archivedCount = builds.length - activeCount;
        listCountEl.textContent = `${activeCount} active${archivedCount ? `, ${archivedCount} archived` : ""}`;
      }
    }

    function showError(message) {
      hideAllStates();
      if (errorTextEl) {
        errorTextEl.textContent = String(message || "Could not load saved builds.");
      }
      if (errorEl) errorEl.hidden = false;
    }

    async function loadBuilds(preferredHandle = selectedHandle) {
      hideAllStates();
      if (statusEl) statusEl.hidden = false;

      if (!listEndpoint) {
        showError("The section is missing a proxy base path.");
        return;
      }

      try {
        const response = await fetch(listEndpoint, {
          credentials: "same-origin",
          headers: {
            Accept: "application/json"
          }
        });

        let data = null;
        try {
          data = await response.json();
        } catch (error) {
          data = null;
        }

        if (!response.ok || !data || !data.ok) {
          showError(
            data && data.error
              ? data.error
              : "The saved-build list route returned an unexpected response."
          );
          return;
        }

        if (!data.loggedIn) {
          currentBuilds = [];
          selectedHandle = "";
          hideAllStates();
          if (authEl) authEl.hidden = false;
          return;
        }

        const builds = Array.isArray(data.builds) ? data.builds : [];
        if (!builds.length) {
          currentBuilds = [];
          selectedHandle = "";
          hideAllStates();
          if (emptyEl) emptyEl.hidden = false;
          return;
        }

        renderBuilds(builds, preferredHandle);
        hideAllStates();
        if (resultsEl) resultsEl.hidden = false;
      } catch (error) {
        showError(error && error.message ? error.message : "Network error while loading saved builds.");
      }
    }

    async function downloadBuildScreenshot(build) {
      const snapshot = getBuildSnapshot(build);
      if (!snapshot || !getSnapshotItems(build).length) {
        throw new Error("Screenshot is available only for builds with snapshot details.");
      }
      if (!window.UCP_PCB_QuoteImage || typeof window.UCP_PCB_QuoteImage.download !== "function") {
        throw new Error("Quote screenshot renderer is missing from theme assets.");
      }

      const resolvedMode =
        typeof window.UCP_PCB_QuoteImage.resolveMode === "function"
          ? window.UCP_PCB_QuoteImage.resolveMode({
              desktopMode: screenshotModeDesktop,
              mobileMode: screenshotModeMobile
            })
          : screenshotModeDesktop;

      return window.UCP_PCB_QuoteImage.download(snapshot, {
        mode: resolvedMode,
        quoteCode: String(build && build.quoteCode ? build.quoteCode : "").trim(),
        quoteVersion: getBuildQuoteVersion(build) || "",
        buildTitle: String(build && build.buildName ? build.buildName : "").trim(),
        brandLogo: screenshotBrandLogo,
        fontPreset: screenshotFontPreset,
        log: false
      });
    }

    function screenshotSuccessMessage(result) {
      if (window.UCP_PCB_QuoteImage && typeof window.UCP_PCB_QuoteImage.resultMessage === "function") {
        return window.UCP_PCB_QuoteImage.resultMessage(result, "Build screenshot");
      }
      return "Build screenshot downloaded.";
    }

    if (retryButton) {
      retryButton.addEventListener("click", () => loadBuilds());
    }

    section.addEventListener("click", async (event) => {
      const listItem = event.target.closest("[data-build-list-item]");
      if (listItem && section.contains(listItem)) {
        const handle = String(listItem.getAttribute("data-build-handle") || "").trim();
        if (handle) selectBuild(handle);
        return;
      }

      const actionButton = event.target.closest("button[data-build-action]");
      if (!actionButton || !section.contains(actionButton)) return;

      const action = String(actionButton.getAttribute("data-build-action") || "").trim();
      const handle = String(actionButton.getAttribute("data-build-handle") || selectedHandle || "").trim();
      const build = findBuild(handle);
      if (!action || !handle || !build) return;

      if (action === "screenshot") {
        setHandleBusy(handle, true);
        try {
          const result = await downloadBuildScreenshot(build);
          showFlash(screenshotSuccessMessage(result));
        } catch (error) {
          showFlash(error && error.message ? error.message : "Could not create the screenshot.", "error");
        } finally {
          setHandleBusy(handle, false);
        }
        return;
      }

      if (action === "delete") {
        const confirmed = window.confirm(`Delete "${build.buildName || "Saved build"}" permanently?`);
        if (!confirmed) return;
      }

      if (action === "rename") {
        const nextName = window.prompt("Rename this build", String(build.buildName || "My Build"));
        if (nextName === null) return;
        setHandleBusy(handle, true);
        try {
          await postBuildAction(handle, "rename", { build_name: nextName });
          await loadBuilds(handle);
          showFlash("Build name updated.");
        } catch (error) {
          showFlash(error && error.message ? error.message : "Could not rename this build.", "error");
        } finally {
          setHandleBusy(handle, false);
        }
        return;
      }

      if (action === "share") {
        const shareUrl = buildTaggedShareUrl(build, "my_builds_share");
        if (!shareUrl) {
          showFlash("This build does not have a shareable restore link yet.", "error");
          return;
        }

        setHandleBusy(handle, true);
        try {
          await postBuildAction(handle, "share");
          let shared = false;

          if (navigator.share) {
            try {
              await navigator.share({
                title: String(build.buildName || "Saved build"),
                text: "Uncapped PC saved build",
                url: shareUrl
              });
              shared = true;
            } catch (error) {
              shared = false;
            }
          }

          if (!shared) {
            const copied = await copyToClipboard(shareUrl);
            if (!copied) {
              throw new Error("Could not copy the share link.");
            }
          }

          await loadBuilds(handle);
          showFlash(shared ? "Share sheet opened." : "Share link copied.");
        } catch (error) {
          showFlash(error && error.message ? error.message : "Could not share this build.", "error");
        } finally {
          setHandleBusy(handle, false);
        }
        return;
      }

      if (action === "archive" || action === "unarchive" || action === "delete") {
        setHandleBusy(handle, true);
        try {
          await postBuildAction(handle, action);
          await loadBuilds(action === "delete" ? "" : handle);
          if (action === "archive") {
            showFlash("Build archived.");
          } else if (action === "unarchive") {
            showFlash("Build restored to your active list.");
          } else {
            showFlash("Build deleted.");
          }
        } catch (error) {
          showFlash(
            error && error.message
              ? error.message
              : action === "delete"
                ? "Could not delete this build."
                : "Could not update this build.",
            "error"
          );
        } finally {
          setHandleBusy(handle, false);
        }
      }
    });

    loadBuilds();
  })();
</script>

