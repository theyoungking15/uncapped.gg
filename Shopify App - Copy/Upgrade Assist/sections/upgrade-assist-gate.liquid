</style>

{% if customer %}
  <script>
    (() => {
      const root = document.querySelector('[data-upgrade-assist-section="{{ section.id }}"]');
      if (!root || root.__upgradeAssistBound) return;
      root.__upgradeAssistBound = true;

      const form = root.querySelector('[data-upgrade-assist-form]');
      if (!form) return;

      const hasBrandOptions = {{ has_brand_options | json }};
      const customerId = {{ customer.id | json }};
      const customerEmail = {{ customer.email | json }};
      const customerPhone = {{ customer.default_address.phone | default: customer.phone | json }};
      const submissionMode = {{ section.settings.submission_mode | json }};
      const localAppSubmitUrl = {{ section.settings.local_app_submit_url | json }};
      const proxySubmitPath = {{ section.settings.proxy_submit_path | json }};
      const sourceInputs = Array.from(form.querySelectorAll('input[name="source_type"]'));
      const submitBtn = form.querySelector('[data-upgrade-assist-submit]');
      const resetBtn = form.querySelector('[data-upgrade-assist-reset]');
      const previewWrap = root.querySelector('[data-upgrade-assist-preview]');
      const previewTitle = root.querySelector('[data-upgrade-assist-preview-title]');
      const previewText = root.querySelector('[data-upgrade-assist-preview-text]');
      const previewCode = root.querySelector('[data-upgrade-assist-preview-code]');
      const productSearchInput = form.querySelector('[data-upgrade-assist-product-search]');
      const productResults = form.querySelector('[data-upgrade-assist-product-results]');
      const selectedProductWrap = form.querySelector('[data-upgrade-assist-selected-product]');
      const selectedProductText = form.querySelector('[data-upgrade-assist-selected-product-text]');
      const clearProductBtn = form.querySelector('[data-upgrade-assist-clear-product]');
      const referencedProductInput = form.querySelector('input[name="referenced_product"]');
      const referencedProductTitleInput = form.querySelector('input[name="referenced_product_title"]');
      const referencedProductUrlInput = form.querySelector('input[name="referenced_product_url"]');
      const photosInput = form.querySelector('input[name="photos"]');
      const proofInput = form.querySelector('input[name="proof_of_purchase_file"]');
      const contactValueInput = form.querySelector('[data-contact-value-input]');
      const contactValueLabel = form.querySelector('[data-contact-value-label]');
      const contactValueHelp = form.querySelector('[data-contact-value-help]');

      let submittedOnce = false;
      let productSearchTimer = null;
      let productSearchNonce = 0;
      const defaultPreviewTitle = previewTitle ? previewTitle.textContent : "";
      const defaultPreviewText = previewText ? previewText.textContent : "";

      function sourceType_() {
        const selected = sourceInputs.find((input) => input.checked);
        return selected ? String(selected.value || "").trim() : "catalog_reference";
      }

      function integrationState_() {
        if (submissionMode === "local_app_direct") return "theme_local_app_direct";
        if (submissionMode === "shopify_app_proxy") return "theme_shopify_app_proxy";
        return "theme_preview_only";
      }

      function submitEndpoint_() {
        if (submissionMode === "local_app_direct") {
          return String(localAppSubmitUrl || "").trim();
        }

        if (submissionMode === "shopify_app_proxy") {
          const raw = String(proxySubmitPath || "").trim();
          return raw || "/apps/upgrade-assist/submit";
        }

        return "";
      }

      function setPreviewOutput_(title, text, value) {
        if (!previewWrap || !previewCode) return;
        previewWrap.hidden = false;
        if (previewTitle) previewTitle.textContent = title || defaultPreviewTitle;
        if (previewText) previewText.textContent = text || defaultPreviewText;
        previewCode.textContent =
          typeof value === "string" ? value : JSON.stringify(value == null ? {} : value, null, 2);
        previewWrap.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function setFieldError_(fieldName, message) {
        const field = form.querySelector('[data-field="' + fieldName + '"]');
        if (!field) return;
        const error = field.querySelector(".upgrade-assist__fieldError");
        field.dataset.invalid = message ? "true" : "false";
        if (!error) return;
        if (message) {
          error.hidden = false;
          error.textContent = message;
        } else {
          error.hidden = true;
          error.textContent = "";
        }
      }

      function clearAllErrors_() {
        form.querySelectorAll("[data-field]").forEach((field) => {
          delete field.dataset.invalid;
          const error = field.querySelector(".upgrade-assist__fieldError");
          if (error) {
            error.hidden = true;
            error.textContent = "";
          }
        });
      }

      function showHideConditional_(selector, shouldShow) {
        form.querySelectorAll(selector).forEach((el) => {
          el.hidden = !shouldShow;
        });
      }

      function syncConditionalUi_() {
        const source = sourceType_();
        const proofStatus = String(form.elements.proof_of_purchase_status.value || "").trim();
        const personalWarranty = String(form.elements.personal_warranty_offered.value || "").trim();
        const contactPreference = String(form.elements.contact_preference.value || "").trim();

        showHideConditional_('[data-ua-when="catalog_reference"]', source === "catalog_reference");
        showHideConditional_('[data-ua-when="manual_entry"]', source === "manual_entry");
        showHideConditional_('[data-ua-proof="picture"]', proofStatus === "picture");
        showHideConditional_('[data-ua-warranty="yes"]', personalWarranty === "yes");
        showHideConditional_('[data-ua-contact-detail]', contactPreference === "phone" || contactPreference === "messenger");

        if (contactValueInput && contactValueLabel && contactValueHelp) {
          if (contactPreference === "phone") {
            contactValueInput.placeholder = "09XXXXXXXXX or full phone number";
            if (!String(contactValueInput.value || "").trim() && customerPhone) {
              contactValueInput.value = String(customerPhone || "").trim();
            }
            contactValueLabel.textContent = "Phone number";
            contactValueHelp.textContent = "Enter the phone number buyers should use for calls or SMS.";
          } else if (contactPreference === "messenger") {
            contactValueInput.placeholder = "Messenger profile link or handle";
            contactValueLabel.textContent = "Messenger handle or link";
            contactValueHelp.textContent = "Enter the Messenger link or handle buyers should use.";
          } else {
            contactValueInput.placeholder = "Messenger handle or phone number";
            contactValueLabel.textContent = "Contact detail";
            contactValueHelp.textContent = "Email uses your Shopify account email. Other methods need a contact value here.";
            if (contactPreference !== "phone" && contactPreference !== "messenger") {
              contactValueInput.value = "";
            }
          }
        }

        if (source !== "catalog_reference" && productResults) {
          productResults.hidden = true;
          productResults.innerHTML = "";
        }
      }

      function updateFileMeta_(input, key) {
        const target = form.querySelector('[data-file-meta-for="' + key + '"]');
        if (!target) return;
        const files = Array.from(input && input.files ? input.files : []);
        if (!files.length) {
          target.textContent = "No files selected.";
          return;
        }
        target.textContent = files.map((file) => file.name).join(", ");
      }

      function setSelectedProduct_(item) {
        const title = item && item.title ? String(item.title) : "";
        const url = item && item.url ? String(item.url) : "";
        const id = item && item.id ? String(item.id) : "";
        const vendor = item && item.vendor ? String(item.vendor) : "";

        referencedProductInput.value = id;
        referencedProductTitleInput.value = title;
        referencedProductUrlInput.value = url;

        if (productSearchInput) productSearchInput.value = title;
        if (selectedProductWrap && selectedProductText) {
          if (title) {
            selectedProductWrap.hidden = false;
            selectedProductText.textContent = vendor ? title + " (" + vendor + ")" : title;
          } else {
            selectedProductWrap.hidden = true;
            selectedProductText.textContent = "";
          }
        }

        if (productResults) {
          productResults.hidden = true;
          productResults.innerHTML = "";
        }
      }

      function clearSelectedProduct_() {
        setSelectedProduct_({ title: "", url: "", id: "", vendor: "" });
        if (productSearchInput) productSearchInput.value = "";
      }

      function renderProductResults_(items, nonce) {
        if (!productResults || nonce !== productSearchNonce) return;
        productResults.innerHTML = "";

        if (!items.length) {
          const empty = document.createElement("div");
          empty.className = "upgrade-assist__searchResult";
          empty.innerHTML = '<span class="upgrade-assist__searchResultMeta">No catalog products matched that search.</span>';
          productResults.appendChild(empty);
          productResults.hidden = false;
          return;
        }

        items.forEach((item) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className = "upgrade-assist__searchResult";
          button.innerHTML =
            '<span><span class="upgrade-assist__searchResultTitle"></span><span class="upgrade-assist__searchResultMeta"></span></span>' +
            '<span class="upgrade-assist__searchResultMeta">Select</span>';
          button.querySelector(".upgrade-assist__searchResultTitle").textContent = item.title || "";
          button.querySelector(".upgrade-assist__searchResultMeta").textContent = item.vendor || item.product_type || "";
          button.addEventListener("click", () => {
            setSelectedProduct_(item);
            validateForm_(submittedOnce);
          });
          productResults.appendChild(button);
        });

        productResults.hidden = false;
      }

      async function fetchProductResults_(query, nonce) {
        const endpoint =
          window.Shopify && window.Shopify.routes && window.Shopify.routes.root
            ? window.Shopify.routes.root
            : "/";

        const url =
          endpoint.replace(/\/?$/, "/") +
          "search/suggest.json?q=" +
          encodeURIComponent(query) +
          "&resources[type]=product&resources[limit]=6&resources[options][unavailable_products]=last";

        const response = await fetch(url, {
          credentials: "same-origin",
          headers: { Accept: "application/json" }
        });

        if (!response.ok) throw new Error("predictive-search-failed");

        const json = await response.json();
        const products =
          json &&
          json.resources &&
          json.resources.results &&
          Array.isArray(json.resources.results.products)
            ? json.resources.results.products
            : [];

        const normalized = products.map((item) => ({
          id: item.id || "",
          title: item.title || "",
          url: item.url || "",
          vendor: item.vendor || "",
          product_type: item.product_type || ""
        }));

        renderProductResults_(normalized, nonce);
      }

      function scheduleProductSearch_() {
        if (!productSearchInput || sourceType_() !== "catalog_reference") return;

        const query = String(productSearchInput.value || "").trim();
        if (query.length < 2) {
          if (productResults) {
            productResults.hidden = true;
            productResults.innerHTML = "";
          }
          return;
        }

        if (productSearchTimer) window.clearTimeout(productSearchTimer);
        const nonce = ++productSearchNonce;

        productSearchTimer = window.setTimeout(() => {
          fetchProductResults_(query, nonce).catch(() => {
            if (!productResults || nonce !== productSearchNonce) return;
            productResults.hidden = false;
            productResults.innerHTML =
              '<div class="upgrade-assist__searchResult"><span class="upgrade-assist__searchResultMeta">Product lookup is temporarily unavailable. Try again.</span></div>';
          });
        }, 220);
      }

      function validateForm_(showErrors) {
        const errors = {};
        const source = sourceType_();
        const askingPrice = Number(form.elements.asking_price.value || 0);
        const externalUrl = String(form.elements.external_product_url.value || "").trim();
        const proofStatus = String(form.elements.proof_of_purchase_status.value || "").trim();
        const personalWarranty = String(form.elements.personal_warranty_offered.value || "").trim();

        if (!source) {
          errors.source_type = "Choose how the item should be identified.";
        }

        if (source === "catalog_reference" && !String(referencedProductInput.value || "").trim()) {
          errors.referenced_product = "Select a product from the store catalog.";
        }

        if (source === "manual_entry") {
          if (!String(form.elements.manual_title.value || "").trim()) {
            errors.manual_title = "Enter the item title.";
          }

          if (hasBrandOptions) {
            if (!String(form.elements.brand_reference.value || "").trim()) {
              errors.brand_reference = "Select the item brand.";
            }
          } else if (!String(form.elements.brand_name_fallback.value || "").trim()) {
            errors.brand_name_fallback = "Enter the item brand.";
          }

          if (externalUrl) {
            try {
              new URL(externalUrl);
            } catch (error) {
              errors.external_product_url = "Enter a valid product URL.";
            }
          }
        }

        if (!Number.isFinite(askingPrice) || askingPrice <= 0) {
          errors.asking_price = "Enter a valid asking price greater than zero.";
        }

        if (!String(form.elements.condition_grade.value || "").trim()) {
          errors.condition_grade = "Choose a condition grade.";
        }

        if (!String(form.elements.city_region.value || "").trim()) {
          errors.city_region = "Enter your city or region.";
        }

        if (!String(form.elements.usage_notes.value || "").trim()) {
          errors.usage_notes = "Add usage notes for the reviewer.";
        }

        if (!photosInput || !photosInput.files || !photosInput.files.length) {
          errors.photos = "Add at least one photo of the item.";
        }

        if (!proofStatus) {
          errors.proof_of_purchase_status = "Choose a proof of purchase status.";
        }

        if (proofStatus === "picture" && (!proofInput || !proofInput.files || !proofInput.files.length)) {
          errors.proof_of_purchase_file = "Add the proof of purchase file.";
        }

        if (!String(form.elements.still_in_warranty.value || "").trim()) {
          errors.still_in_warranty = "Choose whether the item is still in warranty.";
        }

        if (!personalWarranty) {
          errors.personal_warranty_offered = "Choose whether you are offering a personal warranty.";
        }

        if (personalWarranty === "yes" && !String(form.elements.personal_warranty_duration.value || "").trim()) {
          errors.personal_warranty_duration = "Enter the personal warranty duration.";
        }

        if (!String(form.elements.contact_preference.value || "").trim()) {
          errors.contact_preference = "Choose how you want to be contacted.";
        }

        if (
          String(form.elements.contact_preference.value || "").trim() === "email" &&
          !String(customerEmail || "").trim()
        ) {
          errors.contact_preference = "Your Shopify account email is missing. Choose another contact method or update your account first.";
        }

        if (
          ["phone", "messenger"].includes(String(form.elements.contact_preference.value || "").trim()) &&
          !String(form.elements.contact_value.value || "").trim()
        ) {
          errors.contact_value =
            String(form.elements.contact_preference.value || "").trim() === "phone"
              ? "Enter the phone number buyers should use."
              : "Enter the Messenger handle or link buyers should use.";
        }

        if (!form.elements.seller_agreement_accepted.checked) {
          errors.seller_agreement_accepted = "You need to confirm the seller agreement.";
        }

        if (showErrors) {
          clearAllErrors_();
          Object.keys(errors).forEach((field) => setFieldError_(field, errors[field]));
        }

        const isValid = Object.keys(errors).length === 0;
        if (submitBtn) submitBtn.disabled = !isValid;
        return { isValid, errors };
      }

      function buildPayload_() {
        const source = sourceType_();
        const proofStatus = String(form.elements.proof_of_purchase_status.value || "").trim();
        const personalWarranty = String(form.elements.personal_warranty_offered.value || "").trim();
        return {
          status: "pending_review",
          seller_customer_id: customerId,
          source_type: source,
          referenced_product: source === "catalog_reference" ? String(referencedProductInput.value || "").trim() : "",
          referenced_product_title:
            source === "catalog_reference" ? String(referencedProductTitleInput.value || "").trim() : "",
          referenced_product_url:
            source === "catalog_reference" ? String(referencedProductUrlInput.value || "").trim() : "",
          manual_title: source === "manual_entry" ? String(form.elements.manual_title.value || "").trim() : "",
          manual_model: source === "manual_entry" ? String(form.elements.manual_model.value || "").trim() : "",
          external_product_url:
            source === "manual_entry" ? String(form.elements.external_product_url.value || "").trim() : "",
          brand_reference:
            source === "manual_entry" && hasBrandOptions ? String(form.elements.brand_reference.value || "").trim() : "",
          brand_name_fallback:
            source === "manual_entry" && !hasBrandOptions
              ? String(form.elements.brand_name_fallback.value || "").trim()
              : "",
          asking_price: Number(form.elements.asking_price.value || 0),
          condition_grade: String(form.elements.condition_grade.value || "").trim(),
          city_region: String(form.elements.city_region.value || "").trim(),
          usage_notes: String(form.elements.usage_notes.value || "").trim(),
          issue_disclosures: String(form.elements.issue_disclosures.value || "").trim(),
          photos: Array.from(photosInput && photosInput.files ? photosInput.files : []).map((file) => file.name),
          proof_of_purchase_status: proofStatus,
          proof_of_purchase_file:
            proofStatus === "picture"
              ? Array.from(proofInput && proofInput.files ? proofInput.files : []).map((file) => file.name)[0] || ""
              : "",
          personal_warranty_offered: personalWarranty,
          personal_warranty_duration:
            personalWarranty === "yes" ? String(form.elements.personal_warranty_duration.value || "").trim() : "",
          still_in_warranty: String(form.elements.still_in_warranty.value || "").trim(),
          contact_preference: String(form.elements.contact_preference.value || "").trim(),
          contact_value: String(form.elements.contact_value.value || "").trim(),
          seller_agreement_accepted: !!form.elements.seller_agreement_accepted.checked,
          customer_email: String(customerEmail || "").trim(),
          integration_state: integrationState_()
        };
      }

      function buildSubmissionFormData_() {
        const formData = new FormData(form);
        formData.set("seller_customer_id", String(customerId || "").trim());
        if (customerEmail) {
          formData.set("customer_email", String(customerEmail || "").trim());
        }
        formData.set("integration_state", integrationState_());
        return formData;
      }

      function resetPreview_() {
        if (!previewWrap || !previewCode) return;
        previewWrap.hidden = true;
        previewCode.textContent = "";
        if (previewTitle) previewTitle.textContent = defaultPreviewTitle;
        if (previewText) previewText.textContent = defaultPreviewText;
      }

      function handleInputChange_() {
        syncConditionalUi_();
        updateFileMeta_(photosInput, "photos");
        updateFileMeta_(proofInput, "proof_of_purchase_file");
        validateForm_(submittedOnce);
      }

      if (productSearchInput) {
        productSearchInput.addEventListener("input", () => {
          if (
            String(productSearchInput.value || "").trim() !== String(referencedProductTitleInput.value || "").trim()
          ) {
            referencedProductInput.value = "";
            referencedProductTitleInput.value = "";
            referencedProductUrlInput.value = "";
            if (selectedProductWrap) selectedProductWrap.hidden = true;
          }
          scheduleProductSearch_();
          validateForm_(submittedOnce);
        });

        productSearchInput.addEventListener("focus", scheduleProductSearch_);
      }

      if (clearProductBtn) {
        clearProductBtn.addEventListener("click", () => {
          clearSelectedProduct_();
          validateForm_(submittedOnce);
        });
      }

      document.addEventListener("click", (event) => {
        if (!root.contains(event.target) && productResults) {
          productResults.hidden = true;
        }
      });

      sourceInputs.forEach((input) => {
        input.addEventListener("change", () => {
          handleInputChange_();
          resetPreview_();
        });
      });

      form.querySelectorAll("input, select, textarea").forEach((input) => {
        input.addEventListener("change", handleInputChange_);
        input.addEventListener("input", handleInputChange_);
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        submittedOnce = true;
        const validation = validateForm_(true);
        if (!validation.isValid) return;

        const payload = buildPayload_();
        if (submissionMode === "preview_only") {
          setPreviewOutput_(
            "Submission preview",
            "This is a local preview only. No files or listing data were submitted to Shopify from this form.",
            payload
          );

          try {
            console.log("Upgrade Assist submission preview", payload);
          } catch (error) {}
          return;
        }

        const endpoint = submitEndpoint_();
        if (!endpoint) {
          setPreviewOutput_(
            "Submission failed",
            "The submission endpoint is not configured for this mode.",
            { mode: submissionMode }
          );
          return;
        }

        const previousLabel = submitBtn ? submitBtn.textContent : "";
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Submitting...";
        }

        try {
          const response = await fetch(endpoint, {
            method: "POST",
            body: buildSubmissionFormData_(),
            headers: {
              Accept: "application/json"
            },
            mode: submissionMode === "local_app_direct" ? "cors" : "same-origin",
            credentials: submissionMode === "shopify_app_proxy" ? "same-origin" : "omit"
          });

          const contentType = String(response.headers.get("content-type") || "");
          const result = contentType.includes("application/json")
            ? await response.json()
            : { ok: response.ok, text: await response.text() };

          if (!response.ok || !result || result.ok === false) {
            throw {
              status: response.status,
              result: result || { ok: false, error: "unknown_error" }
            };
          }

          setPreviewOutput_(
            "Submission received",
            submissionMode === "local_app_direct"
              ? "The local Upgrade Assist app stored this listing as pending review. Open your local admin page to approve or reject it."
              : "The Upgrade Assist app proxy accepted the submission.",
            result
          );

          try {
            console.log("Upgrade Assist submission sent", {
              endpoint,
              payload,
              result
            });
          } catch (error) {}

          form.reset();
          submittedOnce = false;
          clearAllErrors_();
          clearSelectedProduct_();
          syncConditionalUi_();
          updateFileMeta_(photosInput, "photos");
          updateFileMeta_(proofInput, "proof_of_purchase_file");
          validateForm_(false);
        } catch (error) {
          const details = error && error.result ? error.result : { message: "Submission failed." };
          setPreviewOutput_(
            "Submission failed",
            submissionMode === "local_app_direct"
              ? "The browser could not hand this form to the local Upgrade Assist app. Make sure the app is running on localhost and reachable from this browser."
              : "The Upgrade Assist backend did not accept the submission.",
            details
          );
        } finally {
          if (submitBtn) {
            submitBtn.textContent = previousLabel;
            validateForm_(false);
          }
        }
      });

      if (resetBtn) {
        resetBtn.addEventListener("click", () => {
          form.reset();
          submittedOnce = false;
          clearAllErrors_();
          clearSelectedProduct_();
          syncConditionalUi_();
          updateFileMeta_(photosInput, "photos");
          updateFileMeta_(proofInput, "proof_of_purchase_file");
          resetPreview_();
          validateForm_(false);
        });
      }

      syncConditionalUi_();
      updateFileMeta_(photosInput, "photos");
      updateFileMeta_(proofInput, "proof_of_purchase_file");
      validateForm_(false);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Upgrade Assist gate",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Upgrade Assist"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "We help our buyers sell their old parts."
    },
    {
      "type": "textarea",
      "id": "logged_out_message",
      "label": "Logged out message",
      "default": "Sign in to submit your old component for review. We will help you create a listing if it qualifies."
    },
    {
      "type": "textarea",
      "id": "logged_in_message",
      "label": "Logged in message",
      "default": "You are signed in. Fill out the review form below so the Upgrade Assist team can assess your part."
    },
    {
      "type": "select",
      "id": "submission_mode",
      "label": "Submission mode",
      "default": "local_app_direct",
      "options": [
        {
          "value": "local_app_direct",
          "label": "Direct local app"
        },
        {
          "value": "preview_only",
          "label": "Preview only"
        },
        {
          "value": "shopify_app_proxy",
          "label": "Shopify app proxy"
        }
      ]
    },
    {
      "type": "text",
      "id": "local_app_submit_url",
      "label": "Local app submit URL",
      "default": "http://localhost:3000/api/submissions"
    },
    {
      "type": "text",
      "id": "proxy_submit_path",
      "label": "Shopify app proxy submit path",
      "default": "/apps/upgrade-assist/submit"
    }
  ],
  "presets": [
    {
      "name": "Upgrade Assist gate"
    }
  ]
}
{% endschema %}
