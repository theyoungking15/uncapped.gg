<section class="upgrade-assist page-width section-{{ section.id }}-padding" data-upgrade-assist-section="{{ section.id }}">
  {% assign encoded_return_path = request.path | url_encode %}
  {% assign login_url = '/customer_authentication/login?return_to=' | append: encoded_return_path %}

  {% assign brand_definition = shop.metaobjects.brand %}
  {% assign brand_values = blank %}
  {% if brand_definition != blank %}
    {% assign brand_values = brand_definition.values %}
  {% endif %}
  {% assign brand_option_count = 0 %}
  {% capture brand_options_markup %}
    <option value="">Select brand</option>
    {% for brand in brand_values limit: 250 %}
      {% assign brand_name = brand.name | default: brand.title | default: brand.label | default: brand.system.handle | replace: '-', ' ' | strip %}
      {% assign brand_handle = brand.brand_handle | default: brand.system.handle | default: brand_name | handleize %}
      {% if brand_name != blank %}
        {% assign brand_option_count = brand_option_count | plus: 1 %}
        <option value="{{ brand_handle | escape }}">{{ brand_name | escape }}</option>
      {% endif %}
    {% endfor %}
  {% endcapture %}
  {% assign has_brand_options = false %}
  {% if brand_option_count > 0 %}
    {% assign has_brand_options = true %}
  {% endif %}

  <div class="upgrade-assist__wrap">
    <header class="upgrade-assist__header">
      <h1 class="upgrade-assist__title">{{ section.settings.heading }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="upgrade-assist__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    {% if customer %}
      {% assign account_first_name = customer.first_name | default: '' | strip %}
      {% assign account_last_name = customer.last_name | default: '' | strip %}
      {% assign account_phone = customer.default_address.phone | default: customer.phone | default: '' | strip %}
      {% assign account_profile_complete = true %}
      {% if customer.email == blank or account_first_name == blank or account_last_name == blank or account_phone == blank %}
        {% assign account_profile_complete = false %}
      {% endif %}
      {% assign account_update_url = routes.account_url | default: '/account' %}

      <div class="upgrade-assist__card upgrade-assist__card--in">
        <p class="upgrade-assist__status">Signed in as {{ customer.email }}</p>

        {% if section.settings.logged_in_message != blank %}
          <p class="upgrade-assist__message">{{ section.settings.logged_in_message }}</p>
        {% endif %}

        {% unless account_profile_complete %}
          <div class="upgrade-assist__callout upgrade-assist__callout--warning">
            <h2 class="upgrade-assist__calloutTitle">Complete your account before submitting</h2>
            <p class="upgrade-assist__calloutText">
              Upgrade Assist only accepts listings from customer accounts with complete contact details. Update your account first, then come back here to submit.
            </p>
            <ul class="upgrade-assist__calloutList">
              {% if customer.email == blank %}
                <li>Add an email address to your customer account.</li>
              {% endif %}
              {% if account_first_name == blank %}
                <li>Add your first name to your customer account.</li>
              {% endif %}
              {% if account_last_name == blank %}
                <li>Add your last name to your customer account.</li>
              {% endif %}
              {% if account_phone == blank %}
                <li>Add a phone number to your customer account.</li>
              {% endif %}
            </ul>
            <div class="upgrade-assist__actions">
              <a href="{{ account_update_url }}" class="button button--primary">Complete account</a>
            </div>
          </div>
        {% endunless %}

        <div class="upgrade-assist__callout">
          <h2 class="upgrade-assist__calloutTitle">How Upgrade Assist works</h2>
          <p class="upgrade-assist__calloutText">
            We help our buyers get old parts reviewed for possible listing visibility.
          </p>
          <ul class="upgrade-assist__calloutList">
            <li>Submitting this form does not automatically publish or approve your item.</li>
            <li>Every submission is reviewed first before anything can be shown publicly.</li>
            <li>Uncapped PC helps facilitate visibility, but does not own your item.</li>
          </ul>
        </div>

        {% if account_profile_complete %}
        <form class="upgrade-assist__form" data-upgrade-assist-form novalidate>
          <input type="hidden" name="status" value="pending_review">
          <input type="hidden" name="seller_customer_id" value="{{ customer.id }}">
          <input type="hidden" name="customer_email" value="{{ customer.email }}">
          <input type="hidden" name="customer_first_name" value="{{ account_first_name }}">
          <input type="hidden" name="customer_last_name" value="{{ account_last_name }}">
          <input type="hidden" name="customer_phone" value="{{ account_phone }}">

          <section class="upgrade-assist__formSection" aria-labelledby="upgrade-assist-section-identification-{{ section.id }}">
            <div class="upgrade-assist__sectionHead">
              <h2 id="upgrade-assist-section-identification-{{ section.id }}" class="upgrade-assist__sectionTitle">1. Item Identification</h2>
              <p class="upgrade-assist__sectionText">Tell us whether the part already exists in the store catalog or needs a manual listing reference.</p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full" data-field="source_type">
              <label class="upgrade-assist__label">Source type</label>
              <div class="upgrade-assist__choiceRow">
                <label class="upgrade-assist__choice">
                  <input type="radio" name="source_type" value="catalog_reference" checked>
                  <span>Catalog reference</span>
                </label>
                <label class="upgrade-assist__choice">
                  <input type="radio" name="source_type" value="manual_entry">
                  <span>Manual entry</span>
                </label>
              </div>
              <p class="upgrade-assist__fieldHelp">Choose catalog reference if the original Uncapped PC product already exists in the store.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full" data-field="referenced_product" data-ua-when="catalog_reference">
              <label class="upgrade-assist__label" for="upgrade-assist-product-search-{{ section.id }}">Referenced product</label>
              <input type="hidden" name="referenced_product" value="">
              <input type="hidden" name="referenced_product_title" value="">
              <input type="hidden" name="referenced_product_url" value="">
              <input
                id="upgrade-assist-product-search-{{ section.id }}"
                class="upgrade-assist__input"
                type="search"
                placeholder="Search the store catalog"
                autocomplete="off"
                data-upgrade-assist-product-search
              >
              <div class="upgrade-assist__searchResults" data-upgrade-assist-product-results hidden></div>
              <div class="upgrade-assist__selectedProduct" data-upgrade-assist-selected-product hidden>
                <span data-upgrade-assist-selected-product-text></span>
                <button type="button" class="upgrade-assist__linkButton" data-upgrade-assist-clear-product>Clear</button>
              </div>
              <p class="upgrade-assist__fieldHelp">Pick the closest existing product if your part was originally bought from the store.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="manual_title" data-ua-when="manual_entry" hidden>
              <label class="upgrade-assist__label" for="upgrade-assist-manual-title-{{ section.id }}">Manual title</label>
              <input id="upgrade-assist-manual-title-{{ section.id }}" class="upgrade-assist__input" type="text" name="manual_title" placeholder="Example: MSI GeForce RTX 3070 Gaming X Trio">
              <p class="upgrade-assist__fieldHelp">Use the clearest public-facing title for the part.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="manual_model" data-ua-when="manual_entry" hidden>
              <label class="upgrade-assist__label" for="upgrade-assist-manual-model-{{ section.id }}">Manual model</label>
              <input id="upgrade-assist-manual-model-{{ section.id }}" class="upgrade-assist__input" type="text" name="manual_model" placeholder="Model or SKU if known">
              <p class="upgrade-assist__fieldHelp">Optional, but useful when the exact model matters.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full" data-field="external_product_url" data-ua-when="manual_entry" hidden>
              <label class="upgrade-assist__label" for="upgrade-assist-product-url-{{ section.id }}">External product URL</label>
              <input id="upgrade-assist-product-url-{{ section.id }}" class="upgrade-assist__input" type="url" name="external_product_url" inputmode="url" placeholder="https://">
              <p class="upgrade-assist__fieldHelp">Optional reference link for the exact product page or manufacturer listing.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>
          </section>

          <section class="upgrade-assist__formSection" aria-labelledby="upgrade-assist-section-brand-{{ section.id }}" data-ua-when="manual_entry" hidden>
            <div class="upgrade-assist__sectionHead">
              <h2 id="upgrade-assist-section-brand-{{ section.id }}" class="upgrade-assist__sectionTitle">2. Brand</h2>
              <p class="upgrade-assist__sectionText">Manual entries should be tied to a known brand when possible so review is faster.</p>
            </div>

            {% if has_brand_options %}
              <div class="upgrade-assist__field" data-field="brand_reference">
                <label class="upgrade-assist__label" for="upgrade-assist-brand-reference-{{ section.id }}">Brand</label>
                <select id="upgrade-assist-brand-reference-{{ section.id }}" class="upgrade-assist__select" name="brand_reference">
                  {{ brand_options_markup }}
                </select>
                <p class="upgrade-assist__fieldHelp">This uses the existing brand data already exposed to the theme.</p>
                <p class="upgrade-assist__fieldError" hidden></p>
              </div>
            {% else %}
              <div class="upgrade-assist__field" data-field="brand_name_fallback">
                <label class="upgrade-assist__label" for="upgrade-assist-brand-fallback-{{ section.id }}">Brand name</label>
                <input id="upgrade-assist-brand-fallback-{{ section.id }}" class="upgrade-assist__input" type="text" name="brand_name_fallback" placeholder="Brand name">
                <p class="upgrade-assist__fieldHelp">Brand metaobject options are not exposed here yet, so this is a temporary fallback.</p>
                <p class="upgrade-assist__fieldError" hidden></p>
              </div>
            {% endif %}
          </section>

          <section class="upgrade-assist__formSection" aria-labelledby="upgrade-assist-section-seller-{{ section.id }}">
            <div class="upgrade-assist__sectionHead">
              <h2 id="upgrade-assist-section-seller-{{ section.id }}" class="upgrade-assist__sectionTitle">3. Seller Details</h2>
              <p class="upgrade-assist__sectionText">Give the reviewer enough detail to assess condition, price target, and listing clarity.</p>
            </div>

            <div class="upgrade-assist__field" data-field="asking_price">
              <label class="upgrade-assist__label" for="upgrade-assist-asking-price-{{ section.id }}">Asking price</label>
              <div class="upgrade-assist__inputWithPrefix">
                <span class="upgrade-assist__prefix">PHP</span>
                <input id="upgrade-assist-asking-price-{{ section.id }}" class="upgrade-assist__input" type="number" name="asking_price" min="1" step="1" inputmode="numeric" placeholder="0">
              </div>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="condition_grade">
              <label class="upgrade-assist__label" for="upgrade-assist-condition-{{ section.id }}">Condition grade</label>
              <select id="upgrade-assist-condition-{{ section.id }}" class="upgrade-assist__select" name="condition_grade">
                <option value="">Select condition</option>
                <option value="like_new">Like new</option>
                <option value="excellent">Excellent</option>
                <option value="good">Good</option>
                <option value="fair">Fair</option>
                <option value="for_parts">For parts / issue-disclosed</option>
              </select>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="city_region">
              <label class="upgrade-assist__label" for="upgrade-assist-city-region-{{ section.id }}">City / region</label>
              <input id="upgrade-assist-city-region-{{ section.id }}" class="upgrade-assist__input" type="text" name="city_region" placeholder="City, province, or region">
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full" data-field="usage_notes">
              <label class="upgrade-assist__label" for="upgrade-assist-usage-notes-{{ section.id }}">Usage notes</label>
              <textarea id="upgrade-assist-usage-notes-{{ section.id }}" class="upgrade-assist__textarea" name="usage_notes" rows="4" placeholder="How long the part was used, what system it came from, and anything the reviewer should know."></textarea>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full" data-field="issue_disclosures">
              <label class="upgrade-assist__label" for="upgrade-assist-issues-{{ section.id }}">Issue disclosures</label>
              <textarea id="upgrade-assist-issues-{{ section.id }}" class="upgrade-assist__textarea" name="issue_disclosures" rows="4" placeholder="List dents, scratches, missing accessories, intermittent issues, or repairs."></textarea>
              <p class="upgrade-assist__fieldHelp">Leave blank only if there are no known issues to disclose.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>
          </section>

          <section class="upgrade-assist__formSection" aria-labelledby="upgrade-assist-section-photos-{{ section.id }}">
            <div class="upgrade-assist__sectionHead">
              <h2 id="upgrade-assist-section-photos-{{ section.id }}" class="upgrade-assist__sectionTitle">4. Photos and Proof</h2>
              <p class="upgrade-assist__sectionText">
                {% if section.settings.submission_mode == 'local_app_direct' or section.settings.submission_mode == 'shopify_app_proxy' %}
                  Photos and proof files are submitted with the review request and can be synced into Shopify for the approved listing record.
                {% else %}
                  You can stage photos and proof now. Preview-only mode keeps them inside the browser until a real submission route is used.
                {% endif %}
              </p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full" data-field="photos">
              <label class="upgrade-assist__label" for="upgrade-assist-photos-{{ section.id }}">Photos</label>
              <input id="upgrade-assist-photos-{{ section.id }}" class="upgrade-assist__input upgrade-assist__input--file" type="file" name="photos" accept="image/*" multiple>
              <p class="upgrade-assist__fieldHelp">
                {% if section.settings.submission_mode == 'local_app_direct' or section.settings.submission_mode == 'shopify_app_proxy' %}
                  Selected files are submitted with the review request. The current listing record uses the primary approved photo in Shopify.
                {% else %}
                  Selected files are kept only in the browser preview for now. They are not uploaded in this MVP.
                {% endif %}
              </p>
              <p class="upgrade-assist__fileMeta" data-file-meta-for="photos">No files selected.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="proof_of_purchase_status">
              <label class="upgrade-assist__label" for="upgrade-assist-proof-status-{{ section.id }}">Proof of purchase status</label>
              <select id="upgrade-assist-proof-status-{{ section.id }}" class="upgrade-assist__select" name="proof_of_purchase_status">
                <option value="">Select proof status</option>
                <option value="none">No proof available</option>
                <option value="picture">Picture available</option>
              </select>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="proof_of_purchase_file" data-ua-proof="picture" hidden>
              <label class="upgrade-assist__label" for="upgrade-assist-proof-file-{{ section.id }}">Proof of purchase file</label>
              <input id="upgrade-assist-proof-file-{{ section.id }}" class="upgrade-assist__input upgrade-assist__input--file" type="file" name="proof_of_purchase_file" accept="image/*,.pdf">
              <p class="upgrade-assist__fieldHelp">
                {% if section.settings.submission_mode == 'local_app_direct' or section.settings.submission_mode == 'shopify_app_proxy' %}
                  This file is submitted with the review request and can be stored in Shopify with the approved listing.
                {% else %}
                  This stays local to the browser until a real submission backend is connected.
                {% endif %}
              </p>
              <p class="upgrade-assist__fileMeta" data-file-meta-for="proof_of_purchase_file">No file selected.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>
          </section>

          <section class="upgrade-assist__formSection" aria-labelledby="upgrade-assist-section-warranty-{{ section.id }}">
            <div class="upgrade-assist__sectionHead">
              <h2 id="upgrade-assist-section-warranty-{{ section.id }}" class="upgrade-assist__sectionTitle">5. Warranty</h2>
              <p class="upgrade-assist__sectionText">Capture both manufacturer warranty status and any personal warranty you plan to offer.</p>
            </div>

            <div class="upgrade-assist__field" data-field="still_in_warranty">
              <label class="upgrade-assist__label" for="upgrade-assist-still-in-warranty-{{ section.id }}">Still in warranty</label>
              <select id="upgrade-assist-still-in-warranty-{{ section.id }}" class="upgrade-assist__select" name="still_in_warranty">
                <option value="">Select one</option>
                <option value="yes">Yes</option>
                <option value="no">No</option>
              </select>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="personal_warranty_offered">
              <label class="upgrade-assist__label" for="upgrade-assist-personal-warranty-{{ section.id }}">Personal warranty offered</label>
              <select id="upgrade-assist-personal-warranty-{{ section.id }}" class="upgrade-assist__select" name="personal_warranty_offered">
                <option value="">Select one</option>
                <option value="yes">Yes</option>
                <option value="no">No</option>
              </select>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field" data-field="personal_warranty_duration" data-ua-warranty="yes" hidden>
              <label class="upgrade-assist__label" for="upgrade-assist-warranty-duration-{{ section.id }}">Personal warranty duration</label>
              <input id="upgrade-assist-warranty-duration-{{ section.id }}" class="upgrade-assist__input" type="text" name="personal_warranty_duration" placeholder="Example: 7 days personal warranty">
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>
          </section>

          <section class="upgrade-assist__formSection" aria-labelledby="upgrade-assist-section-contact-{{ section.id }}">
            <div class="upgrade-assist__sectionHead">
              <h2 id="upgrade-assist-section-contact-{{ section.id }}" class="upgrade-assist__sectionTitle">6. Contact and Agreement</h2>
              <p class="upgrade-assist__sectionText">Tell the reviewer how you want to be contacted and confirm that the information is accurate.</p>
            </div>

            <div class="upgrade-assist__field" data-field="contact_preference">
              <label class="upgrade-assist__label" for="upgrade-assist-contact-preference-{{ section.id }}">Contact preference</label>
              <select id="upgrade-assist-contact-preference-{{ section.id }}" class="upgrade-assist__select" name="contact_preference">
                <option value="">Select contact preference</option>
                <option value="email">Email</option>
                <option value="messenger">Messenger</option>
                <option value="phone">Phone / SMS</option>
              </select>
              <p class="upgrade-assist__fieldHelp">Email uses your Shopify account email. Messenger and phone require a contact value below.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full" data-field="contact_value" data-ua-contact-detail hidden>
              <label class="upgrade-assist__label" for="upgrade-assist-contact-value-{{ section.id }}" data-contact-value-label>Contact detail</label>
              <input
                id="upgrade-assist-contact-value-{{ section.id }}"
                class="upgrade-assist__input"
                type="text"
                name="contact_value"
                placeholder="Messenger handle or phone number"
                data-contact-value-input
              >
              <p class="upgrade-assist__fieldHelp" data-contact-value-help>Enter the exact contact detail buyers should use after approval.</p>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>

            <div class="upgrade-assist__field upgrade-assist__field--full upgrade-assist__field--checkbox" data-field="seller_agreement_accepted">
              <label class="upgrade-assist__checkbox">
                <input type="checkbox" name="seller_agreement_accepted" value="true">
                <span>I confirm the details above are accurate and I understand this submission is only a review request, not an automatic listing.</span>
              </label>
              <p class="upgrade-assist__fieldError" hidden></p>
            </div>
          </section>

          <div class="upgrade-assist__submitArea">
            <div class="upgrade-assist__submitNote">
              <strong>Current submission mode:</strong>
              {% case section.settings.submission_mode %}
                {% when 'local_app_direct' %}
                  direct local app. This form sends data straight to your local Upgrade Assist app endpoint.
                {% when 'shopify_app_proxy' %}
                  Shopify app proxy. This form submits through the storefront proxy route.
                {% else %}
                  preview only. This theme version does not send data to a backend yet.
              {% endcase %}
            </div>
            <div class="upgrade-assist__actions">
              <button type="submit" class="button button--primary" data-upgrade-assist-submit disabled>
                {% case section.settings.submission_mode %}
                  {% when 'local_app_direct' %}
                    Submit to local review app
                  {% when 'shopify_app_proxy' %}
                    Submit for review
                  {% else %}
                    Review submission preview
                {% endcase %}
              </button>
              <button type="button" class="button button--secondary" data-upgrade-assist-reset>
                Reset form
              </button>
            </div>
            <p class="upgrade-assist__submitHint">
              {% case section.settings.submission_mode %}
                {% when 'local_app_direct' %}
                  When valid, this sends the submission to your local Upgrade Assist app at the configured local endpoint.
                {% when 'shopify_app_proxy' %}
                  When valid, this sends the submission through the configured Shopify app proxy route.
                {% else %}
                  When valid, the form will generate a local payload preview and log it to the browser console for backend integration handoff.
              {% endcase %}
            </p>
          </div>
        </form>

        <div class="upgrade-assist__preview" data-upgrade-assist-preview hidden>
          <div class="upgrade-assist__previewHead">
            <h2 class="upgrade-assist__sectionTitle" data-upgrade-assist-preview-title>
              {% if section.settings.submission_mode == 'preview_only' %}
                Submission preview
              {% else %}
                Submission result
              {% endif %}
            </h2>
            <p class="upgrade-assist__previewText" data-upgrade-assist-preview-text>
              {% if section.settings.submission_mode == 'local_app_direct' %}
                This panel shows the local app response after submission.
              {% elsif section.settings.submission_mode == 'shopify_app_proxy' %}
                This panel shows the app proxy response after submission.
              {% else %}
                This is a local preview only. No files or listing data were submitted to Shopify from this form.
              {% endif %}
            </p>
          </div>
          <pre class="upgrade-assist__previewCode" data-upgrade-assist-preview-code></pre>
        </div>
        {% endif %}
      </div>
    {% else %}
      <div class="upgrade-assist__card upgrade-assist__card--out">
        {% if section.settings.logged_out_message != blank %}
          <p class="upgrade-assist__message">{{ section.settings.logged_out_message }}</p>
        {% endif %}

        <div class="upgrade-assist__actions">
          <a href="{{ login_url }}" class="button button--primary">
            Sign in to continue
          </a>

          {% if routes.account_register_url != blank %}
            <a href="{{ routes.account_register_url }}" class="button button--secondary">
              Create account
            </a>
          {% endif %}
        </div>

        <div class="upgrade-assist__note">
          <small>
            After signing in, you will be returned to this page.
          </small>
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .upgrade-assist__wrap {
    max-width: 920px;
    margin: 0 auto;
  }

  .upgrade-assist__header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .upgrade-assist__title {
    margin: 0 0 0.75rem;
  }

  .upgrade-assist__subheading {
    margin: 0;
    opacity: 0.8;
  }

  .upgrade-assist__card {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 18px;
    padding: 2rem;
    background: rgb(var(--color-background));
  }

  .upgrade-assist__status {
    margin-top: 0;
    font-size: 0.95rem;
    opacity: 0.75;
  }

  .upgrade-assist__message {
    margin-bottom: 1.5rem;
  }

  .upgrade-assist__callout {
    margin-bottom: 1.75rem;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(0, 0, 0, 0.025);
  }

  .upgrade-assist__callout--warning {
    border-color: rgba(181, 137, 0, 0.28);
    background: rgba(255, 246, 223, 0.9);
    color: rgb(107, 82, 0);
  }

  .upgrade-assist__calloutTitle {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

