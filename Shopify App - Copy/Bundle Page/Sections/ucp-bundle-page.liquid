{%- comment -%}
  File: sections/ucp-bundle-page.liquid

  Updates in this version
  1. Mobile. Show the CPU bundle header first (above the image).
     Implementation. Duplicate header (mobile and desktop). CSS toggles visibility.

  2. Sorting and filters
     - Sort. Recommended, Lowest price, Highest price
     - Filter. Brand (from product.vendor), Chipset (from product.metafields.custom.chipset)
     Chipset is optional. If no chipset data exists, the chipset filter auto-hides.

  3. Spacing controls remain. Width, padding, 60/40 columns, image sizing controls.

  Notes for chipset
  - Add a motherboard metafield: namespace custom, key chipset (single line text)
  - Example values: B850, X870E, B650, etc.
{%- endcomment -%}

{%- liquid
  assign cpu_ref = page.metafields.custom.bundle_cpu
  assign builder_page_url = section.settings.pc_builder_page_url | strip
  if builder_page_url == ''
    assign builder_page_url = '/pages/pc-builder-2'
  endif
  assign cpu_product = blank
  if cpu_ref != blank
    if cpu_ref.value != blank
      assign cpu_product = cpu_ref.value
    else
      assign cpu_product = cpu_ref
    endif
  endif

  assign rules_def = shop.metaobjects['cpu_motherboard_bundle']

  assign brand_mo = shop.metaobjects.brand['uncapped']
  assign brand_logo_media = blank
  if brand_mo != blank
    if brand_mo.logo != blank
      assign brand_logo_media = brand_mo.logo.value
    elsif brand_mo.image != blank
      assign brand_logo_media = brand_mo.image.value
    elsif brand_mo.brand_logo != blank
      assign brand_logo_media = brand_mo.brand_logo.value
    endif
  endif

  capture brand_logo_url
    if brand_logo_media != blank
      echo brand_logo_media | image_url: width: 360
    elsif shop.brand.logo != blank
      echo shop.brand.logo | image_url: width: 360
    elsif settings.logo != blank
      echo settings.logo | image_url: width: 360
    endif
  endcapture
-%}
{% if section.settings.debug %}
  <pre class="ucp-bundle-debug">rules_def probe:
{{ rules_def['ryzen-7-9800x3d-gigabyte-b550m-aorus-elite'] }}
{{ rules_def['gigabyte-b550m-aorus-elite'] }}
  </pre>
{% endif %}
{%- liquid

  assign candidate_collection = collections[section.settings.bundle_motherboards_collection]
  if candidate_collection == blank
    assign candidate_collection = collections['bundle-motherboard']
  endif
  if candidate_collection == blank
    assign candidate_collection = collections['motherboards']
  endif

  assign debug_on = section.settings.debug | default: false

  assign cpu_bench_handle = ''
  if cpu_product != blank
    assign cpu_bench_handle = cpu_product.metafields.custom.bench_cpu_handle | default: '' | strip | downcase
    if cpu_bench_handle == ''
      assign cpu_bench_handle = cpu_product.handle | default: '' | downcase
    endif
  endif

  assign rows_packed = ''
  assign matches = 0
  assign debug_lines = ''

  comment
    Layout tokens
  endcomment
  assign wrapper_class = 'ucp-bundle-wrap'
  if section.settings.width == 'page'
    assign wrapper_class = wrapper_class | append: ' is-page'
  else
    assign wrapper_class = wrapper_class | append: ' is-full'
  endif

  assign max_width = section.settings.max_width | default: 1200 | plus: 0
  if max_width < 720
    assign max_width = 1200
  endif

  assign pad_desktop = section.settings.pad_desktop | default: 24 | plus: 0
  assign pad_mobile  = section.settings.pad_mobile  | default: 16 | plus: 0

  assign grid_gap = section.settings.grid_gap | default: 18 | plus: 0

  assign left_percent = section.settings.left_percent | default: 60 | plus: 0
  if left_percent < 50
    assign left_percent = 60
  endif
  if left_percent > 75
    assign left_percent = 60
  endif
  assign right_percent = 100 | minus: left_percent

  assign hero_min_h_desktop = section.settings.hero_min_h_desktop | default: 420 | plus: 0
  assign hero_min_h_mobile  = section.settings.hero_min_h_mobile  | default: 300 | plus: 0

  assign frame_padding = section.settings.frame_padding | default: 14 | plus: 0

  assign cpu_thumb_size = section.settings.cpu_thumb_size | default: 54 | plus: 0

  assign mobo_zoom = section.settings.mobo_zoom | default: 100 | plus: 0
  if mobo_zoom < 80
    assign mobo_zoom = 80
  endif
  if mobo_zoom > 130
    assign mobo_zoom = 130
  endif
  assign mobo_zoom_scale = mobo_zoom | times: 0.01

  assign mobo_fit = section.settings.mobo_fit | default: 'contain' | downcase
  if mobo_fit != 'cover' and mobo_fit != 'contain'
    assign mobo_fit = 'contain'
  endif

  assign default_sort = section.settings.default_sort | default: 'price_asc' | downcase
  if default_sort == '' or default_sort == 'recommended'
    assign default_sort = 'price_asc'
  endif
  if default_sort != 'sort_order' and default_sort != 'price_asc' and default_sort != 'price_desc'
    assign default_sort = 'price_asc'
  endif
-%}

{%- if cpu_product == blank -%}
  {%- if debug_on -%}
    <div class="ucp-bundle-empty">
      Bundle page debug. page.metafields.custom.bundle_cpu is empty.
    </div>
  {%- endif -%}

{%- elsif rules_def == blank -%}
  {%- if debug_on -%}
    <div class="ucp-bundle-empty">
      Bundle page debug. shop.metaobjects['cpu_motherboard_bundle'] not found.
    </div>
  {%- endif -%}

{%- else -%}

  {%- if candidate_collection == blank or candidate_collection.products_count == 0 -%}
    <div class="ucp-bundle-empty">
      No bundle motherboard collection found.
    </div>

  {%- else -%}

    {%- liquid
      assign max_mobos = section.settings.max_motherboards | default: 200 | plus: 0
      if max_mobos < 1
        assign max_mobos = 200
      endif
    -%}

    {%- paginate candidate_collection.products by 250 -%}
      {%- for mobo_product in candidate_collection.products -%}
        {%- if forloop.index > max_mobos -%}{% break %}{%- endif -%}

        {%- liquid
          assign debug_reason = ''
          assign rule_handle = ''

          assign mobo_bench_handle = mobo_product.metafields.custom.bench_motherboard_handle | default: '' | strip | downcase
          if mobo_bench_handle == ''
            assign mobo_bench_handle = mobo_product.handle | default: '' | downcase
          endif
          if mobo_bench_handle == ''
            assign debug_reason = 'skip:no_mobo_handle'
            if debug_on
              assign debug_line = mobo_product.handle | default: ''
              assign debug_line = debug_line | append: ' | mobo_bench="' | append: mobo_bench_handle | append: '"'
              assign debug_line = debug_line | append: ' | mobo_title="' | append: mobo_product.title | strip | append: '"'
              assign debug_line = debug_line | append: ' | rule="' | append: rule_handle | append: '"'
              assign debug_line = debug_line | append: ' | status=' | append: debug_reason
              if debug_lines == ''
                assign debug_lines = debug_line
              else
                assign debug_lines = debug_lines | append: '<br>' | append: debug_line
              endif
            endif
            continue
          endif

          assign rule_handle = cpu_bench_handle | append: '-' | append: mobo_bench_handle
          assign rule = rules_def[rule_handle]
          if rule == blank
            assign debug_reason = 'skip:no_rule'
            if debug_on
              assign debug_line = mobo_product.handle | default: ''
              assign debug_line = debug_line | append: ' | mobo_bench="' | append: mobo_bench_handle | append: '"'
              assign debug_line = debug_line | append: ' | mobo_title="' | append: mobo_product.title | strip | append: '"'
              assign debug_line = debug_line | append: ' | rule="' | append: rule_handle | append: '"'
              assign debug_line = debug_line | append: ' | status=' | append: debug_reason
              if debug_lines == ''
                assign debug_lines = debug_line
              else
                assign debug_lines = debug_lines | append: '<br>' | append: debug_line
              endif
            endif
            continue
          endif

          assign active_flag = rule.is_active
          unless active_flag == true or active_flag == 'true' or active_flag == 1 or active_flag == '1'
            assign debug_reason = 'skip:inactive'
            if debug_on
              assign debug_line = mobo_product.handle | default: ''
              assign debug_line = debug_line | append: ' | mobo_bench="' | append: mobo_bench_handle | append: '"'
              assign debug_line = debug_line | append: ' | mobo_title="' | append: mobo_product.title | strip | append: '"'
              assign debug_line = debug_line | append: ' | rule="' | append: rule_handle | append: '"'
              assign debug_line = debug_line | append: ' | status=' | append: debug_reason
              if debug_lines == ''
                assign debug_lines = debug_line
              else
                assign debug_lines = debug_lines | append: '<br>' | append: debug_line
              endif
            endif
            continue
          endunless

          assign matches = matches | plus: 1

          assign cpu_var_ref = rule.cpu_variant
          assign cpu_variant = cpu_var_ref
          if cpu_var_ref != blank and cpu_var_ref.value != blank
            assign cpu_variant = cpu_var_ref.value
          endif
          if cpu_variant == blank
            assign cpu_variant = cpu_product.selected_or_first_available_variant
          endif

          assign mobo_var_ref = rule.motherboard_variant
          if mobo_var_ref == blank
            assign mobo_var_ref = rule.motherboard_varinat
          endif
          assign mobo_variant = mobo_var_ref
          if mobo_var_ref != blank and mobo_var_ref.value != blank
            assign mobo_variant = mobo_var_ref.value
          endif
          if mobo_variant == blank
            assign mobo_variant = mobo_product.selected_or_first_available_variant
          endif

          assign cpu_price_cents = 0
          if cpu_variant != blank and cpu_variant.price != blank
            assign cpu_price_cents = cpu_variant.price | plus: 0
          endif

          assign mobo_price_cents = 0
          if mobo_variant != blank and mobo_variant.price != blank
            assign mobo_price_cents = mobo_variant.price | plus: 0
          endif

          assign discount_units = rule.discount_amount | default: 0 | plus: 0
          assign savings_cents = discount_units | times: 100
          assign bundle_price_cents = cpu_price_cents | plus: mobo_price_cents | minus: savings_cents

          assign sort_num = rule.sort_order | default: 999999 | plus: 0
          assign sort_key = sort_num | append: ''
          assign sort_key = '000000' | append: sort_key
          assign sort_key = sort_key | slice: -6, 6

          assign cpu_variant_id = ''
          if cpu_variant and cpu_variant.id
            assign cpu_variant_id = cpu_variant.id
          endif

          assign mobo_variant_id = ''
          if mobo_variant and mobo_variant.id
            assign mobo_variant_id = mobo_variant.id
          endif

          if cpu_variant_id == '' or mobo_variant_id == ''
            assign debug_reason = 'skip:missing_variant'
            if debug_on
              assign debug_line = mobo_product.handle | default: ''
              assign debug_line = debug_line | append: ' | mobo_bench="' | append: mobo_bench_handle | append: '"'
              assign debug_line = debug_line | append: ' | mobo_title="' | append: mobo_product.title | strip | append: '"'
              assign debug_line = debug_line | append: ' | rule="' | append: rule_handle | append: '"'
              assign debug_line = debug_line | append: ' | status=' | append: debug_reason
              if debug_lines == ''
                assign debug_lines = debug_line
              else
                assign debug_lines = debug_lines | append: '<br>' | append: debug_line
              endif
            endif
            continue
          endif

          assign cpu_variant_match = false
          for v in cpu_product.variants
            if v.id == cpu_variant_id
              assign cpu_variant_match = true
              break
            endif
          endfor

          unless cpu_variant_match
            assign debug_reason = 'skip:cpu_variant_mismatch'
            if debug_on
              assign debug_line = mobo_product.handle | default: ''
              assign debug_line = debug_line | append: ' | mobo_bench="' | append: mobo_bench_handle | append: '"'
              assign debug_line = debug_line | append: ' | mobo_title="' | append: mobo_product.title | strip | append: '"'
              assign debug_line = debug_line | append: ' | rule="' | append: rule_handle | append: '"'
              assign debug_line = debug_line | append: ' | status=' | append: debug_reason
              if debug_lines == ''
                assign debug_lines = debug_line
              else
                assign debug_lines = debug_lines | append: '<br>' | append: debug_line
              endif
            endif
            continue
          endunless

          assign mobo_variant_match = false
          for v in mobo_product.variants
            if v.id == mobo_variant_id
              assign mobo_variant_match = true
              break
            endif
          endfor

          unless mobo_variant_match
            assign debug_reason = 'skip:mobo_variant_mismatch'
            if debug_on
              assign debug_line = mobo_product.handle | default: ''
              assign debug_line = debug_line | append: ' | mobo_bench="' | append: mobo_bench_handle | append: '"'
              assign debug_line = debug_line | append: ' | mobo_title="' | append: mobo_product.title | strip | append: '"'
              assign debug_line = debug_line | append: ' | rule="' | append: rule_handle | append: '"'
              assign debug_line = debug_line | append: ' | status=' | append: debug_reason
              if debug_lines == ''
                assign debug_lines = debug_line
              else
                assign debug_lines = debug_lines | append: '<br>' | append: debug_line
              endif
            endif
            continue
          endunless

          assign mobo_img = ''
          if mobo_product.featured_image
            assign mobo_img = mobo_product.featured_image | image_url: width: 1400
          endif

          comment
            Filters. Brand from vendor. Chipset from custom.chipset (optional).
          endcomment
          assign brand_name = mobo_product.vendor | default: '' | strip
          if brand_name == ''
            assign brand_name = 'Other'
          endif
          assign brand_key = brand_name | handleize | downcase

          assign chipset_name = ''
          if mobo_product.metafields.custom and mobo_product.metafields.custom.chipset != blank
            assign chipset_name = mobo_product.metafields.custom.chipset.value | default: mobo_product.metafields.custom.chipset
          endif
          assign chipset_name = chipset_name | strip
          assign chipset_key = ''
          if chipset_name != ''
            assign chipset_key = chipset_name | handleize | downcase
          endif

          if debug_on
            assign debug_reason = 'ok'
            assign debug_line = mobo_product.handle | default: ''
              assign debug_line = debug_line | append: ' | mobo_bench="' | append: mobo_bench_handle | append: '"'
              assign debug_line = debug_line | append: ' | mobo_title="' | append: mobo_product.title | strip | append: '"'
              assign debug_line = debug_line | append: ' | rule="' | append: rule_handle | append: '"'
            assign debug_line = debug_line | append: ' | status=' | append: debug_reason
            if debug_lines == ''
              assign debug_lines = debug_line
            else
              assign debug_lines = debug_lines | append: '<br>' | append: debug_line
            endif
          endif
        -%}

        {%- capture row_html -%}
          <label class="ucp-bundle-chooser__row"
            data-ucp-bundle-row
            data-sort-order="{{ sort_num }}"
            data-bundle-price-cents="{{ bundle_price_cents }}"
            data-brand-key="{{ brand_key | escape }}"
            data-brand-name="{{ brand_name | escape }}"
            data-chipset-key="{{ chipset_key | escape }}"
            data-chipset-name="{{ chipset_name | escape }}"
          >
            <input
              class="ucp-bundle-chooser__radio"
              type="radio"
              name="ucp_bundle_pick"
              value="{{ mobo_product.handle | escape }}"
              data-mobo-handle="{{ mobo_product.handle | escape }}"
              data-cpu-variant-id="{{ cpu_variant_id }}"
              data-mobo-variant-id="{{ mobo_variant_id }}"
              data-mobo-title="{{ mobo_product.title | strip | escape }}"
              data-mobo-url="{{ mobo_product.url | escape }}"
              data-mobo-img="{{ mobo_img | escape }}"
              data-bundle-price="{{ bundle_price_cents | money | strip_html | escape }}"
              data-savings="{{ savings_cents | money | strip_html | escape }}"
              data-savings-cents="{{ savings_cents }}"
              aria-label="Select {{ mobo_product.title | escape }}"
            >
            <span class="ucp-bundle-chooser__row-main">
              <span class="ucp-bundle-chooser__row-title">{{ mobo_product.title }}</span>
              <span class="ucp-bundle-chooser__row-badges" aria-hidden="true"></span>
            </span>

            <span class="ucp-bundle-chooser__row-price">{{ bundle_price_cents | money }}</span>
          </label>
        {%- endcapture -%}

        {%- capture pack -%}{{ sort_key }}::{{ row_html }}{%- endcapture -%}
        {%- if rows_packed == '' -%}
          {%- assign rows_packed = pack -%}
        {%- else -%}
          {%- assign rows_packed = rows_packed | append: '||' | append: pack -%}
        {%- endif -%}

      {%- endfor -%}
    {%- endpaginate -%}

    {%- assign rows = rows_packed | split: '||' | sort -%}

    {%- if rows.size == 0 or rows_packed == '' -%}
      <div class="ucp-bundle-empty">
        No active bundle rules found for this CPU using the selected motherboard collection.
      </div>
    {%- else -%}

      <div class="{{ wrapper_class }}"
        style="
          --ucp-bundle-max-width: {{ max_width }}px;
          --ucp-bundle-pad-desktop: {{ pad_desktop }}px;
          --ucp-bundle-pad-mobile: {{ pad_mobile }}px;
          --ucp-bundle-gap: {{ grid_gap }}px;
          --ucp-bundle-left-fr: {{ left_percent }}fr;
          --ucp-bundle-right-fr: {{ right_percent }}fr;
          --ucp-bundle-hero-min-h: {{ hero_min_h_desktop }}px;
          --ucp-bundle-hero-min-h-mobile: {{ hero_min_h_mobile }}px;
          --ucp-bundle-frame-pad: {{ frame_padding }}px;
          --ucp-bundle-cpu-thumb: {{ cpu_thumb_size }}px;
          --ucp-bundle-mobo-zoom: {{ mobo_zoom_scale }};
        ">

        <section class="ucp-bundle-chooser"
          data-ucp-bundle-chooser
          data-ucp-source-page-type="bundle_page"
          data-ucp-source-campaign="{{ page.handle | default: page.title | handleize | escape }}"
          data-ucp-source-content="{{ cpu_product.handle | default: cpu_product.title | handleize | escape }}"
          data-default-sort="{{ default_sort }}"
          data-pc-builder-url="{{ builder_page_url | escape }}"
          data-bundle-page-handle="{{ page.handle | default: page.title | handleize | escape }}"
          data-html2canvas-src="{{ 'html2canvas.min.js' | asset_url | escape }}"
          data-screenshot-brand-logo="{{ brand_logo_url | strip | escape }}"
          data-cpu-title="{{ cpu_product.title | strip | escape }}"
          data-cpu-img="{% if cpu_product.featured_image %}{{ cpu_product.featured_image | image_url: width: 600 }}{% endif %}">

          {%- comment -%}
            Mobile header. Visible on mobile only.
          {%- endcomment -%}
          <div class="ucp-bundle-chooser__header ucp-bundle-chooser__header--mobile">
            {%- if cpu_product.featured_image -%}
              <img
                class="ucp-bundle-chooser__cpu-thumb"
                loading="lazy"
                src="{{ cpu_product.featured_image | image_url: width: 200 }}"
                alt="{{ cpu_product.title | escape }}">
            {%- endif -%}

            <div class="ucp-bundle-chooser__header-text">
              <h2 class="ucp-bundle-chooser__title">{{ cpu_product.title }} Bundle</h2>
              <div class="ucp-bundle-chooser__sub">
                Pick one motherboard. Add both to cart. Discount applies via the existing automatic discount at checkout.
              </div>
            </div>
          </div>

          <div class="ucp-bundle-chooser__grid">

            <!-- LEFT. Motherboard image emphasis -->
            <div class="ucp-bundle-chooser__left">
              <div class="ucp-bundle-chooser__image-frame">
                <div class="ucp-bundle-chooser__img-wrap ucp-bundle-chooser__img-wrap--hero">
                  <img
                    class="ucp-bundle-chooser__img ucp-bundle-chooser__img--mobo ucp-fit-{{ mobo_fit }}"
                    loading="lazy"
                    src=""
                    alt="Selected motherboard"
                    data-ucp-selected-mobo-img>
                </div>
              </div>
            </div>

            <!-- RIGHT. Header (desktop only) + filters + options + summary + CTA -->
            <div class="ucp-bundle-chooser__right">

              {%- comment -%}
                Desktop header. Hidden on mobile.
              {%- endcomment -%}
              <div class="ucp-bundle-chooser__header ucp-bundle-chooser__header--desktop">
                {%- if cpu_product.featured_image -%}
                  <img
                    class="ucp-bundle-chooser__cpu-thumb"
                    loading="lazy"
                    src="{{ cpu_product.featured_image | image_url: width: 200 }}"
                    alt="{{ cpu_product.title | escape }}">
                {%- endif -%}

                <div class="ucp-bundle-chooser__header-text">
                  <h2 class="ucp-bundle-chooser__title">{{ cpu_product.title }} Bundle</h2>
                  <div class="ucp-bundle-chooser__sub">
                    Pick one motherboard. Add both to cart. Discount applies via the existing automatic discount at checkout.
                  </div>
                </div>
              </div>

              {% if section.settings.enable_filters %}
                <div class="ucp-bundle-filters" data-ucp-bundle-filters>
                  <div class="ucp-bundle-filters__row">
                    <div class="ucp-filter">
                      <label class="ucp-filter__label" for="ucpSort-{{ section.id }}">Sort</label>
                      <select id="ucpSort-{{ section.id }}" class="ucp-filter__select" data-ucp-sort>
                        <option value="sort_order" {% if default_sort == 'sort_order' %}selected{% endif %}>Rule order</option>
                        <option value="price_asc" {% if default_sort == 'price_asc' %}selected{% endif %}>Lowest price</option>
                        <option value="price_desc" {% if default_sort == 'price_desc' %}selected{% endif %}>Highest price</option>
                      </select>
                    </div>

                    <div class="ucp-filter" data-ucp-brand-wrap>
                      <label class="ucp-filter__label" for="ucpBrand-{{ section.id }}">Brand</label>
                      <select id="ucpBrand-{{ section.id }}" class="ucp-filter__select" data-ucp-brand>
                        <option value="">All</option>
                      </select>
                    </div>

                    <div class="ucp-filter" data-ucp-chipset-wrap>
                      <label class="ucp-filter__label" for="ucpChipset-{{ section.id }}">Chipset</label>
                      <select id="ucpChipset-{{ section.id }}" class="ucp-filter__select" data-ucp-chipset>
                        <option value="">All</option>
                      </select>
                    </div>
                  </div>
                </div>
              {% endif %}

              <div class="ucp-bundle-chooser__table" role="group" aria-label="Bundle motherboard options">
                <div class="ucp-bundle-chooser__thead">
                  <div class="ucp-bundle-chooser__th ucp-bundle-chooser__th--name">Motherboard</div>
                  <div class="ucp-bundle-chooser__th ucp-bundle-chooser__th--price">Bundle price</div>
                </div>

                <div class="ucp-bundle-chooser__tbody" data-ucp-bundle-tbody>
                  {%- for r in rows -%}
                    {%- if r == blank -%}{% continue %}{%- endif -%}
                    {%- assign parts = r | split: '::' -%}
                    {%- if parts.size < 2 -%}{% continue %}{%- endif -%}
                    {{ parts[1] }}
                  {%- endfor -%}
                </div>
              </div>

              <div class="ucp-bundle-summary" data-ucp-bundle-summary>
                <div class="ucp-bundle-summary__label">Selected bundle</div>
                <div class="ucp-bundle-summary__title" data-ucp-summary-title>
                  CPU {{ cpu_product.title }} + Motherboard
                </div>
                <div class="ucp-bundle-summary__line">
                  Bundle price <strong data-ucp-summary-price></strong>
                </div>
                <div class="ucp-bundle-summary__save" data-ucp-summary-save>
                  You save <strong data-ucp-summary-savings></strong> vs buying separately
                </div>
              </div>

              <div class="ucp-bundle-chooser__cta-wrap">
                <button type="button"
                  class="ucp-bundle-chooser__cta"
                  data-ucp-open-builder
                  disabled>
                  Open in PC Builder
                </button>

                {% if section.settings.enable_add_to_cart_cta %}
                  <button type="button"
                    class="ucp-bundle-chooser__cta ucp-bundle-chooser__cta--secondary"
                    data-ucp-add-selected
                    data-ucp-track-click
                    data-ucp-track-cta="add_bundle_to_cart"
                    data-ucp-track-page-type="bundle_page"
                    disabled>
                    Add CPU + motherboard to cart
                  </button>
                {% endif %}

                <div class="ucp-bundle-chooser__error" data-ucp-bundle-error hidden></div>
              </div>

              <div class="ucp-bundle-dev" data-ucp-bundle-dev hidden>
                <div class="ucp-bundle-dev__eyebrow">Dev tools</div>
                <div class="ucp-bundle-dev__title">Visible bundle screenshot</div>
                <div class="ucp-bundle-dev__text">
                  Downloads one promo image using the current sort and filter state on this bundle page.
                </div>
                <button type="button" class="ucp-bundle-dev__btn" data-ucp-bundle-dev-screenshot>
                  Download visible bundle price list
                </button>
