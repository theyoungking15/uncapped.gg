          function downloadCanvas(canvas, filename) {
            function clickDownload(url) {
              var link = document.createElement('a');
              link.href = url;
              link.download = filename;
              document.body.appendChild(link);
              link.click();
              document.body.removeChild(link);
            }

            if (canvas.toBlob) {
              return new Promise(function (resolve) {
                canvas.toBlob(function (blob) {
                  if (!blob) {
                    clickDownload(canvas.toDataURL('image/png'));
                    resolve();
                    return;
                  }

                  var url = URL.createObjectURL(blob);
                  clickDownload(url);
                  setTimeout(function () {
                    URL.revokeObjectURL(url);
                  }, 1000);
                  resolve();
                }, 'image/png');
              });
            }

            clickDownload(canvas.toDataURL('image/png'));
            return Promise.resolve();
          }

          function generateVisibleBundleScreenshot() {
            var items = getVisibleBundleItems();
            if (!items.length) {
              setDevStatus('No visible bundles to screenshot. Clear filters or pick another page.', true);
              return;
            }

            if (devShotBtn) {
              devShotBtn.disabled = true;
              devShotBtn.textContent = 'Generating...';
            }
            var startedAt = Date.now();
            setDevStatus('Preparing screenshot...', false);

            loadHtml2Canvas()
              .then(function (html2canvas) {
                var node = buildBundleScreenshotNode(items);
                var card = node.firstChild;
                var width = 1080;
                var height = Math.ceil(card.getBoundingClientRect().height);

                setDevStatus('Rendering screenshot...', false);

                return html2canvas(card, {
                  backgroundColor: '#f4f0e9',
                  scale: BUNDLE_SCREENSHOT_SCALE,
                  useCORS: true,
                  imageTimeout: BUNDLE_SCREENSHOT_IMAGE_TIMEOUT,
                  logging: false,
                  windowWidth: width,
                  windowHeight: height,
                  width: width,
                  height: height
                }).then(function (canvas) {
                  setDevStatus('Downloading screenshot...', false);
                  return downloadCanvas(canvas, 'uncapped-bundles-' + safeFilePart(bundlePageHandle) + '-' + bundleScreenshotFileDate() + '.png')
                    .then(function () {
                      document.body.removeChild(node);
                      var elapsed = Math.max(1, Math.round((Date.now() - startedAt) / 1000));
                      setDevStatus('Screenshot downloaded for ' + items.length + ' visible bundle option' + (items.length === 1 ? '' : 's') + ' in ' + elapsed + 's.', false);
                    });
                }).catch(function (err) {
                  if (node && node.parentNode) node.parentNode.removeChild(node);
                  throw err;
                });
              })
              .catch(function () {
                setDevStatus('Could not generate screenshot. Confirm html2canvas.min.js is uploaded to theme assets.', true);
              })
              .finally(function () {
                if (devShotBtn) {
                  devShotBtn.disabled = false;
                  devShotBtn.textContent = 'Download visible bundle price list';
                }
              });
          }

          function buildFilterOptions() {
            if (!brandSelect || !chipsetSelect) return;

            var rows = getRows();

            var brandMap = {};
            var chipsetMap = {};

            rows.forEach(function (row) {
              var bk = (row.getAttribute('data-brand-key') || '').toLowerCase();
              var bn = row.getAttribute('data-brand-name') || '';
              if (bk && bn && !brandMap[bk]) brandMap[bk] = bn;

              var ck = (row.getAttribute('data-chipset-key') || '').toLowerCase();
              var cn = row.getAttribute('data-chipset-name') || '';
              if (ck && cn && !chipsetMap[ck]) chipsetMap[ck] = cn;
            });

            var brandKeys = Object.keys(brandMap).sort(function (a, b) {
              return brandMap[a].localeCompare(brandMap[b]);
            });

            var chipsetKeys = Object.keys(chipsetMap).sort(function (a, b) {
              return chipsetMap[a].localeCompare(chipsetMap[b]);
            });

            brandSelect.innerHTML = '<option value="">All</option>';
            brandKeys.forEach(function (k) {
              var opt = document.createElement('option');
              opt.value = k;
              opt.textContent = brandMap[k];
              brandSelect.appendChild(opt);
            });

            chipsetSelect.innerHTML = '<option value="">All</option>';
            chipsetKeys.forEach(function (k) {
              var opt = document.createElement('option');
              opt.value = k;
              opt.textContent = chipsetMap[k];
              chipsetSelect.appendChild(opt);
            });

            if (brandWrap) {
              brandWrap.style.display = brandKeys.length > 1 ? '' : 'none';
            }

            if (chipsetWrap) {
              chipsetWrap.style.display = chipsetKeys.length > 0 ? '' : 'none';
            }
          }

          function applySortAndFilters() {
            var rows = getRows();
            if (!rows.length || !tbody) return;

            var sortMode = (sortSelect && sortSelect.value) ? sortSelect.value : (root.getAttribute('data-default-sort') || 'price_asc');
            sortMode = (sortMode || 'price_asc').toLowerCase();

            var brandMode = (brandSelect && brandSelect.value) ? brandSelect.value.toLowerCase() : '';
            var chipsetMode = (chipsetSelect && chipsetSelect.value) ? chipsetSelect.value.toLowerCase() : '';

            var visible = [];
            var hidden = [];

            rows.forEach(function (row, idx) {
              var bk = (row.getAttribute('data-brand-key') || '').toLowerCase();
              var ck = (row.getAttribute('data-chipset-key') || '').toLowerCase();

              var okBrand = !brandMode || (bk === brandMode);
              var okChip = !chipsetMode || (ck === chipsetMode);

              row.__origIndex = row.__origIndex || idx;

              if (okBrand && okChip) {
                row.style.display = '';
                visible.push(row);
              } else {
                row.style.display = 'none';
                hidden.push(row);
              }
            });

            function numAttr(el, name, fallback) {
              var v = parseFloat(el.getAttribute(name) || '');
              return isNaN(v) ? (fallback || 0) : v;
            }

            visible.sort(function (a, b) {
              if (sortMode === 'price_asc' || sortMode === 'price_desc') {
                var pa = numAttr(a, 'data-bundle-price-cents', 0);
                var pb = numAttr(b, 'data-bundle-price-cents', 0);
                if (pa !== pb) {
                  return sortMode === 'price_asc' ? (pa - pb) : (pb - pa);
                }
              } else {
                var sa = numAttr(a, 'data-sort-order', 999999);
                var sb = numAttr(b, 'data-sort-order', 999999);
                if (sa !== sb) return sa - sb;
              }
              return (a.__origIndex || 0) - (b.__origIndex || 0);
            });

            visible.forEach(function (row) { tbody.appendChild(row); });
            hidden.forEach(function (row) { tbody.appendChild(row); });

            var picked = getSelectedRadio();
            if (picked) {
              var pickedRow = picked.closest('[data-ucp-bundle-row]');
              if (pickedRow && pickedRow.style.display === 'none') {
                var next = firstVisibleRadio();
                if (next) {
                  next.checked = true;
                  applySelected(next);
                } else {
                  applySelected(null);
                }
              }
            } else {
              var first = firstVisibleRadio();
              if (first) {
                first.checked = true;
                applySelected(first);
              }
            }
          }

          root.addEventListener('change', function (e) {
            var t = e.target;
            if (!t) return;

            if (t.matches('input[name="ucp_bundle_pick"]')) {
              applySelected(t);
              return;
            }

            if (t.matches('[data-ucp-sort]') || t.matches('[data-ucp-brand]') || t.matches('[data-ucp-chipset]')) {
              applySortAndFilters();
              return;
            }
          });

          if (addBtn) {
            addBtn.addEventListener('click', function (e) {
              e.preventDefault();
              addSelectedToCart();
            });
          }
          if (builderBtn) {
            builderBtn.addEventListener('click', function (e) {
              e.preventDefault();
              openSelectedInBuilder();
            });
          }
          if (devShotBtn) {
            devShotBtn.addEventListener('click', function (e) {
              e.preventDefault();
              generateVisibleBundleScreenshot();
            });
          }

          buildFilterOptions();

          var radios = getRadios();
          if (radios.length) {
            if (!getSelectedRadio()) {
              radios[0].checked = true;
            }
            applySelected(getSelectedRadio());
          }

          applySortAndFilters();
        })();
      </script>

    {%- endif -%}

  {%- endif -%}

{%- endif -%}

<script src="{{ 'ucp-source-tracker.js' | asset_url }}" defer></script>

