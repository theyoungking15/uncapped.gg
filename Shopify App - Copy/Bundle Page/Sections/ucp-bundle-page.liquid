      </style>

      <script>
        (function () {
          var root = document.querySelector('[data-ucp-bundle-chooser]');
          if (!root) return;

          var tbody = root.querySelector('[data-ucp-bundle-tbody]');
          var moboImgEl = root.querySelector('[data-ucp-selected-mobo-img]');
          var addBtn = root.querySelector('[data-ucp-add-selected]');
          var builderBtn = root.querySelector('[data-ucp-open-builder]');
          var errEl = root.querySelector('[data-ucp-bundle-error]');
          var builderUrl = root.getAttribute('data-pc-builder-url') || '/pages/pc-builder-2';
          var bundlePageHandle = root.getAttribute('data-bundle-page-handle') || '';

          var cpuTitle = root.getAttribute('data-cpu-title') || '';
          var sumTitleEl = root.querySelector('[data-ucp-summary-title]');
          var sumPriceEl = root.querySelector('[data-ucp-summary-price]');
          var sumSavingsEl = root.querySelector('[data-ucp-summary-savings]');

          var sortSelect = root.querySelector('[data-ucp-sort]');
          var brandWrap = root.querySelector('[data-ucp-brand-wrap]');
          var brandSelect = root.querySelector('[data-ucp-brand]');
          var chipsetWrap = root.querySelector('[data-ucp-chipset-wrap]');
          var chipsetSelect = root.querySelector('[data-ucp-chipset]');
          var devPanel = root.querySelector('[data-ucp-bundle-dev]');
          var devShotBtn = root.querySelector('[data-ucp-bundle-dev-screenshot]');
          var devStatusEl = root.querySelector('[data-ucp-bundle-dev-status]');
          var html2canvasSrc = root.getAttribute('data-html2canvas-src') || '';
          var BUNDLE_SCREENSHOT_SCALE = 1.25;
          var BUNDLE_SCREENSHOT_IMAGE_TIMEOUT = 8000;
          var isDevMode = false;

          try {
            isDevMode = new URLSearchParams(window.location.search).get('dev') === '1';
          } catch (err) {
            isDevMode = false;
          }

          if (devPanel) {
            devPanel.hidden = !isDevMode;
          }

          function clearError() {
            if (!errEl) return;
            errEl.hidden = true;
            errEl.textContent = '';
          }

          function showError(msg) {
            if (!errEl) return;
            errEl.hidden = false;
            errEl.textContent = msg || 'Could not add bundle. Please try again.';
          }

          function getRadios() {
            return Array.prototype.slice.call(root.querySelectorAll('input[name="ucp_bundle_pick"]'));
          }

          function getRows() {
            return Array.prototype.slice.call(root.querySelectorAll('[data-ucp-bundle-row]'));
          }

          function getSelectedRadio() {
            var radios = getRadios();
            for (var i = 0; i < radios.length; i++) {
              if (radios[i].checked) return radios[i];
            }
            return null;
          }

          function firstVisibleRadio() {
            var rows = getRows();
            for (var i = 0; i < rows.length; i++) {
              if (rows[i].style.display === 'none') continue;
              var r = rows[i].querySelector('input[name="ucp_bundle_pick"]');
              if (r) return r;
            }
            return null;
          }

          function applySelected(radio) {
            if (!radio) {
              if (addBtn) addBtn.disabled = true;
              if (builderBtn) builderBtn.disabled = true;
              return;
            }

            clearError();

            var moboTitle = radio.getAttribute('data-mobo-title') || 'Motherboard';
            var bundlePrice = radio.getAttribute('data-bundle-price') || '';
            var savings = radio.getAttribute('data-savings') || '';
            var moboImg = radio.getAttribute('data-mobo-img') || '';

            if (sumTitleEl) sumTitleEl.textContent = 'CPU ' + cpuTitle + ' + ' + moboTitle;
            if (sumPriceEl) sumPriceEl.textContent = bundlePrice;
            if (sumSavingsEl) sumSavingsEl.textContent = savings;

            if (moboImgEl) {
              if (moboImg) {
                moboImgEl.src = moboImg;
                moboImgEl.alt = moboTitle;
              }
            }

            if (addBtn) addBtn.disabled = false;
            if (builderBtn) builderBtn.disabled = false;
          }

          function openSelectedInBuilder() {
            var picked = getSelectedRadio();
            if (!picked) return;

            clearError();

            var cpuId = picked.getAttribute('data-cpu-variant-id');
            var moboId = picked.getAttribute('data-mobo-variant-id');
            if (!cpuId || !moboId) {
              showError('Selected bundle is missing variant ids.');
              return;
            }

            try {
              var url = new URL(builderUrl, window.location.origin);
              url.searchParams.set('cpu', String(cpuId));
              url.searchParams.set('mb', String(moboId));
              var moboHandle = picked.getAttribute('data-mobo-handle') || picked.value || '';
              applyMarketingParamsToUrl(url, {
                sourceTag: 'bundle_page',
                campaign: bundlePageHandle,
                content: moboHandle
              });
              if (window.UCP_SOURCE_TRACKER && typeof window.UCP_SOURCE_TRACKER.logCtaClick === 'function') {
                window.UCP_SOURCE_TRACKER.logCtaClick({
                  pageType: 'bundle_page',
                  ctaName: 'open_in_pc_builder',
                  targetUrl: url.toString()
                });
              }
              window.location.assign(url.toString());
            } catch (err) {
              showError('Could not open this bundle in PC Builder.');
            }
          }

          function applyMarketingParamsToUrl(url, fallbacks) {
            if (!url || !url.searchParams) return;
            fallbacks = fallbacks || {};

            if (window.UCP_SOURCE_TRACKER && typeof window.UCP_SOURCE_TRACKER.decorateUrl === 'function') {
              try {
                var decorated = new URL(window.UCP_SOURCE_TRACKER.decorateUrl(url.toString(), fallbacks));
                url.search = decorated.search;
                return;
              } catch (err) {}
            }

            try {
              var current = new URLSearchParams(window.location.search || '');
              var sourceValue = current.get('src') || current.get('source') || current.get('ref') || fallbacks.sourceTag || '';
              var campaignValue = current.get('campaign') || current.get('utm_campaign') || fallbacks.campaign || '';
              var contentValue = current.get('content') || current.get('utm_content') || fallbacks.content || '';

              if (!url.searchParams.get('src') && !url.searchParams.get('source') && !url.searchParams.get('ref') && sourceValue) {
                url.searchParams.set('src', sourceValue);
              }
              if (!url.searchParams.get('campaign') && !url.searchParams.get('utm_campaign') && campaignValue) {
                url.searchParams.set('campaign', campaignValue);
              }
              if (!url.searchParams.get('content') && !url.searchParams.get('utm_content') && contentValue) {
                url.searchParams.set('content', contentValue);
              }
            } catch (err) {}
          }

          function addSelectedToCart() {
            var picked = getSelectedRadio();
            if (!picked) return;

            clearError();

            var cpuId = picked.getAttribute('data-cpu-variant-id');
            var moboId = picked.getAttribute('data-mobo-variant-id');
            if (!cpuId || !moboId) {
              showError('Selected bundle is missing variant ids.');
              return;
            }

            if (addBtn) {
              addBtn.disabled = true;
              addBtn.setAttribute('data-loading', 'true');
              addBtn.textContent = 'Adding...';
            }

            var payload = {
              items: [
                { id: cpuId, quantity: 1 },
                { id: moboId, quantity: 1 }
              ]
            };

            fetch('/cart/add.js', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify(payload)
            })
            .then(function (r) {
              if (!r.ok) throw new Error('Cart add failed');
              return r.json();
            })
            .then(function () {
              if (addBtn) {
                addBtn.textContent = 'Added to cart';
                addBtn.removeAttribute('data-loading');
              }
              document.dispatchEvent(new CustomEvent('uncapped:cart-updated'));
            })
            .catch(function () {
              if (addBtn) {
                addBtn.disabled = false;
                addBtn.textContent = 'Add CPU + motherboard to cart';
                addBtn.removeAttribute('data-loading');
              }
              showError('Could not add bundle. Please try again.');
            });
          }

          function setDevStatus(msg, isError) {
            if (!devStatusEl) return;
            devStatusEl.hidden = !msg;
            devStatusEl.textContent = msg || '';
            devStatusEl.classList.toggle('is-error', !!isError);
          }

          function loadHtml2Canvas() {
            if (window.html2canvas) return Promise.resolve(window.html2canvas);
            if (!html2canvasSrc) return Promise.reject(new Error('Missing html2canvas asset URL.'));

            if (window.__ucpBundleHtml2CanvasPromise) {
              return window.__ucpBundleHtml2CanvasPromise;
            }

            window.__ucpBundleHtml2CanvasPromise = new Promise(function (resolve, reject) {
              var script = document.createElement('script');
              script.src = html2canvasSrc;
              script.async = true;
              script.onload = function () {
                if (window.html2canvas) {
                  resolve(window.html2canvas);
                } else {
                  reject(new Error('html2canvas did not load.'));
                }
              };
              script.onerror = function () {
                reject(new Error('Could not load html2canvas.'));
              };
              document.head.appendChild(script);
            });

            return window.__ucpBundleHtml2CanvasPromise;
          }

          function makeEl(tag, className, text, cssText) {
            var node = document.createElement(tag);
            if (className) node.className = className;
            if (typeof text === 'string') node.textContent = text;
            if (cssText) node.style.cssText = cssText;
            return node;
          }

          function selectedOptionText(selectEl, fallback) {
            if (!selectEl || !selectEl.value) return fallback || 'All';
            var opt = selectEl.options[selectEl.selectedIndex];
            return opt ? opt.textContent : (fallback || 'All');
          }

          function bundleScreenshotDate() {
            try {
              return new Date().toLocaleDateString('en-PH', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              });
            } catch (err) {
              return new Date().toISOString().slice(0, 10);
            }
          }

          function bundleScreenshotFileDate() {
            try {
              return new Date().toISOString().slice(0, 10);
            } catch (err) {
              return 'bundle-prices';
            }
          }

          function safeFilePart(value) {
            return String(value || 'bundles')
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, '-')
              .replace(/^-+|-+$/g, '')
              .slice(0, 80) || 'bundles';
          }

          function numberAttr(el, name, fallback) {
            var raw = el ? parseFloat(el.getAttribute(name) || '') : NaN;
            return isNaN(raw) ? (fallback || 0) : raw;
          }

          function getVisibleBundleItems() {
            return getRows()
              .filter(function (row) {
                return row.style.display !== 'none';
              })
              .map(function (row) {
                var radio = row.querySelector('input[name="ucp_bundle_pick"]');
                var titleEl = row.querySelector('.ucp-bundle-chooser__row-title');
                var priceEl = row.querySelector('.ucp-bundle-chooser__row-price');
                return {
                  title: radio ? (radio.getAttribute('data-mobo-title') || radio.value || '') : (titleEl ? titleEl.textContent : ''),
                  price: radio ? (radio.getAttribute('data-bundle-price') || '') : (priceEl ? priceEl.textContent : ''),
                  savings: radio ? (radio.getAttribute('data-savings') || '') : '',
                  priceCents: numberAttr(row, 'data-bundle-price-cents', 0),
                  savingsCents: numberAttr(radio, 'data-savings-cents', 0),
                  chipset: row.getAttribute('data-chipset-name') || ''
                };
              });
          }

          function findMinItem(items, key) {
            var best = null;
            items.forEach(function (item) {
              var val = Number(item && item[key]);
              if (!Number.isFinite(val)) return;
              if (!best || val < best.value) {
                best = { item: item, value: val };
              }
            });
            return best ? best.item : null;
          }

          function findMaxItem(items, key) {
            var best = null;
            items.forEach(function (item) {
              var val = Number(item && item[key]);
              if (!Number.isFinite(val)) return;
              if (!best || val > best.value) {
                best = { item: item, value: val };
              }
            });
            return best ? best.item : null;
          }

          function buildSocialIcon(url, label, size) {
            var icon = makeEl('div', '', '', [
              'width:' + size + 'px',
              'height:' + size + 'px',
              'border-radius:999px',
              'display:flex',
              'align-items:center',
              'justify-content:center',
              'overflow:hidden'
            ].join(';'));

            var img = makeEl('img');
            img.src = url;
            img.alt = label || '';
            img.crossOrigin = 'anonymous';
            img.referrerPolicy = 'no-referrer';
            img.style.cssText = 'width:100%;height:100%;object-fit:contain;display:block;';
            icon.appendChild(img);
            return icon;
          }

          function appendBundleSocials(parent) {
            var socials = makeEl('div', '', '', 'display:flex;flex-direction:column;align-items:center;gap:8px;margin-top:24px;');
            var icons = makeEl('div', '', '', 'display:flex;align-items:center;justify-content:center;gap:10px;');
            [
              { label: 'Facebook', url: 'https://cdn.shopify.com/s/files/1/0681/3368/3337/files/FB.png?v=1769187883' },
              { label: 'Instagram', url: 'https://cdn.shopify.com/s/files/1/0681/3368/3337/files/IG.png?v=1769187884' },
              { label: 'YouTube', url: 'https://cdn.shopify.com/s/files/1/0681/3368/3337/files/youtube.png?v=1769187883' },
              { label: 'TikTok', url: 'https://cdn.shopify.com/s/files/1/0681/3368/3337/files/Tiktok.png?v=1769187884' }
            ].forEach(function (icon) {
              icons.appendChild(buildSocialIcon(icon.url, icon.label, 30));
            });

            socials.appendChild(icons);
            socials.appendChild(makeEl('div', '', '', 'width:220px;height:1px;background:rgba(17,17,17,.55);'));
            socials.appendChild(makeEl('div', '', 'Follow us @ Uncapped PC', 'font-size:13px;font-weight:500;letter-spacing:.02em;color:rgba(17,17,17,.72);'));
            parent.appendChild(socials);
          }

          function buildBundleScreenshotNode(items) {
            var cpuImg = root.getAttribute('data-cpu-img') || '';
            var brandLogo = root.getAttribute('data-screenshot-brand-logo') || '';
