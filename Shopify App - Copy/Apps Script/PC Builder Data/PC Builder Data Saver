function doPost(e) {
  // Accept "data" as urlencoded JSON string, to avoid CORS issues
  const raw =
    (e && e.parameter && e.parameter.data) ? e.parameter.data :
    (e && e.postData && e.postData.contents) ? e.postData.contents :
    '';

  if (!raw) return json_({ ok: false, error: 'Missing data' });

  const dataStr = normalizeBody_(raw);

  let body;
  try {
    body = JSON.parse(dataStr);
  } catch (err) {
    return json_({ ok: false, error: 'Invalid JSON' });
  }

  if (body.secret !== SECRET) {
    return json_({ ok: false, error: 'Unauthorized' });
  }

  const p = body.payload || {};

  const ss = getSpreadsheet_();
  if (!ss) {
    return json_({
      ok: false,
      error: 'No spreadsheet found. Bind this script to a Google Sheet, or set SPREADSHEET_ID.'
    });
  }

  if (isSourceEvent_(p.event)) {
    appendSourceEvent_(ss, p);
    rebuildSourceDailySummary_(ss);
    rebuildSourceCampaignDailySummary_(ss);
    return json_({ ok: true });
  }

  const sheet = ss.getSheetByName('build_logs') || ss.insertSheet('build_logs');

  const headers = ensureHeaders_(sheet);

  const row = buildRow_(p, headers);
  sheet.appendRow(row);

  try {
    if (p && p.quoteCode) upsertQuote_(ss, p);
  } catch (e) {}

  return json_({ ok: true });
}

function getSpreadsheet_() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    if (ss) return ss;
  } catch (e) {}

  const id = String(SPREADSHEET_ID || '').trim();
  if (!id) return null;

  try {
    return SpreadsheetApp.openById(id);
  } catch (e) {
    return null;
  }
}

function normalizeBody_(raw) {
  let s = String(raw || '').trim();

  // If postData.contents comes in as "data=...."
  if (s.startsWith('data=')) s = s.slice(5);

  // Try decodeURIComponent if it looks encoded
  try {
    if (/%7B|%22|%3A|%2C/i.test(s)) s = decodeURIComponent(s);
  } catch (e) {}

  return s.trim();
}

/**
 * Ensures row 1 has headers in the desired order.
 * If headers changed, existing data rows are remapped by header name so values stay aligned.
 * Returns the final header row as an array, in the sheet's actual order.
 */
function ensureHeaders_(sheet) {
  return ensureSheetHeaders_(sheet, SCHEMA_HEADERS);
}

function ensureSheetHeaders_(sheet, expectedHeaders) {
  const lastRow = sheet.getLastRow();

  if (lastRow === 0) {
    sheet.appendRow(expectedHeaders);
    return expectedHeaders.slice();
  }

  const lastCol = Math.max(1, sheet.getLastColumn());
  const existing = sheet.getRange(1, 1, 1, lastCol).getValues()[0]
    .map((x) => String(x || '').trim());

  const needRewrite =
    existing.length !== expectedHeaders.length ||
    expectedHeaders.some((h, idx) => (existing[idx] || '') !== h);

  if (needRewrite) {
    const dataRows = Math.max(0, lastRow - 1);
    let reorderedRows = [];

    if (dataRows > 0) {
      const rawRows = sheet.getRange(2, 1, dataRows, lastCol).getValues();
      reorderedRows = rawRows.map((row) => {
        const source = {};
        existing.forEach((header, idx) => {
          if (!header) return;
          source[header] = row[idx];
        });
        return expectedHeaders.map((header) => (header in source ? source[header] : ''));
      });
    }

    sheet.clearContents();
    sheet.getRange(1, 1, 1, expectedHeaders.length).setValues([expectedHeaders]);
    if (reorderedRows.length) {
      sheet.getRange(2, 1, reorderedRows.length, expectedHeaders.length).setValues(reorderedRows);
    }
    return expectedHeaders.slice();
  }

  const headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0]
    .map((x) => String(x || '').trim());

  return headers;
}

