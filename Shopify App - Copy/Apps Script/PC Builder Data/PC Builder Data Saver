function rebuildSourceDailySummary_(ss) {
  const rawSheet = ss.getSheetByName('link_source_events') || ss.insertSheet('link_source_events');
  const summarySheet = ss.getSheetByName('link_source_daily') || ss.insertSheet('link_source_daily');
  const rawHeaders = ensureSheetHeaders_(rawSheet, SOURCE_EVENT_HEADERS);

  ensureSheetHeaders_(summarySheet, SOURCE_DAILY_HEADERS);

  const lastRow = rawSheet.getLastRow();
  const rows = lastRow > 1
    ? rawSheet.getRange(2, 1, lastRow - 1, rawHeaders.length).getValues()
    : [];

  const indexByHeader = {};
  rawHeaders.forEach((header, idx) => {
    indexByHeader[header] = idx;
  });

  const counts = {};
  rows.forEach((row) => {
    const date = String(row[indexByHeader.date] || '').trim();
    const event = normalizeSourceTag_(row[indexByHeader.event]) || 'link_open';
    const pageType = normalizeSourceTag_(row[indexByHeader.pageType]);
    const sourceTag = normalizeSourceTag_(row[indexByHeader.sourceTag]);
    if (!date || !sourceTag) return;
    const key = [date, event, pageType, sourceTag].join('||');
    counts[key] = (counts[key] || 0) + 1;
  });

  const summaryRows = Object.keys(counts)
    .sort((a, b) => {
      const [dateA] = a.split('||');
      const [dateB] = b.split('||');
      if (dateA === dateB) return a.localeCompare(b);
      return dateA < dateB ? 1 : -1;
    })
    .map((key) => {
      const [date, event, pageType, sourceTag] = key.split('||');
      return [date, event, pageType, sourceTag, counts[key]];
    });

  summarySheet.clearContents();
  summarySheet.getRange(1, 1, 1, SOURCE_DAILY_HEADERS.length).setValues([SOURCE_DAILY_HEADERS]);
  if (summaryRows.length) {
    summarySheet.getRange(2, 1, summaryRows.length, SOURCE_DAILY_HEADERS.length).setValues(summaryRows);
  }
}

function rebuildSourceCampaignDailySummary_(ss) {
  const rawSheet = ss.getSheetByName('link_source_events') || ss.insertSheet('link_source_events');
  const summarySheet = ss.getSheetByName('link_source_campaign_daily') || ss.insertSheet('link_source_campaign_daily');
  const rawHeaders = ensureSheetHeaders_(rawSheet, SOURCE_EVENT_HEADERS);

  ensureSheetHeaders_(summarySheet, SOURCE_CAMPAIGN_DAILY_HEADERS);

  const lastRow = rawSheet.getLastRow();
  const rows = lastRow > 1
    ? rawSheet.getRange(2, 1, lastRow - 1, rawHeaders.length).getValues()
    : [];

  const indexByHeader = {};
  rawHeaders.forEach((header, idx) => {
    indexByHeader[header] = idx;
  });

  const counts = {};
  rows.forEach((row) => {
    const date = String(row[indexByHeader.date] || '').trim();
    const sourceTag = normalizeSourceTag_(row[indexByHeader.sourceTag]);
    if (!date || !sourceTag) return;

    const event = normalizeSourceTag_(row[indexByHeader.event]) || 'link_open';
    const pageType = normalizeSourceTag_(row[indexByHeader.pageType]);
    const campaign = normalizeSourceTag_(row[indexByHeader.campaign]);
    const content = normalizeSourceTag_(row[indexByHeader.content]);
    const promoHandle = normalizeSourceTag_(row[indexByHeader.promoHandle]);
    const ctaName = normalizeSourceTag_(row[indexByHeader.ctaName]);
    const deviceType = String(row[indexByHeader.deviceType] || '').trim().toLowerCase();
    const key = [date, event, pageType, sourceTag, campaign, content, promoHandle, ctaName, deviceType].join('||');
    counts[key] = (counts[key] || 0) + 1;
  });

  const summaryRows = Object.keys(counts)
    .sort((a, b) => {
      const aParts = a.split('||');
      const bParts = b.split('||');
      if (aParts[0] !== bParts[0]) return aParts[0] < bParts[0] ? 1 : -1;
      return a.localeCompare(b);
    })
    .map((key) => {
      const [date, event, pageType, sourceTag, campaign, content, promoHandle, ctaName, deviceType] = key.split('||');
      return [date, event, pageType, sourceTag, campaign, content, promoHandle, ctaName, deviceType, counts[key]];
    });

  summarySheet.clearContents();
  summarySheet.getRange(1, 1, 1, SOURCE_CAMPAIGN_DAILY_HEADERS.length).setValues([SOURCE_CAMPAIGN_DAILY_HEADERS]);
  if (summaryRows.length) {
    summarySheet.getRange(2, 1, summaryRows.length, SOURCE_CAMPAIGN_DAILY_HEADERS.length).setValues(summaryRows);
  }
}

function json_(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function doGet(e) {
  const action = (e && e.parameter && e.parameter.action) ? String(e.parameter.action) : '';
  if (action !== 'get_quote') return jsjsonp_({ ok: false, error: 'Invalid action' }, e);

  const quote = (e.parameter && e.parameter.quote) ? String(e.parameter.quote).trim() : '';
  const v = (e.parameter && e.parameter.v) ? String(e.parameter.v).trim() : '1';
  if (!quote) return jsjsonp_({ ok: false, error: 'Missing quote' }, e);

  const payloadJson = findQuotePayload_(quote, v);
  if (!payloadJson) return jsjsonp_({ ok: false, error: 'Not found' }, e);

  let payload;
  try { payload = JSON.parse(payloadJson); } catch (_) { payload = payloadJson; }

  return jsjsonp_({ ok: true, payload: payload }, e);
}

function jsjsonp_(obj, e) {
  const cb = (e && e.parameter && e.parameter.callback) ? String(e.parameter.callback) : '';
  const safeCb = /^[a-zA-Z_$][0-9a-zA-Z_$]*$/.test(cb) ? cb : 'callback';
  const body = `${safeCb}(${JSON.stringify(obj)});`;
  return ContentService.createTextOutput(body).setMimeType(ContentService.MimeType.JAVASCRIPT);
}

function upsertQuote_(ss, payload) {
  const sheet = ss.getSheetByName('quotes') || ss.insertSheet('quotes');

  // Ensure headers exist
  if (sheet.getLastRow() === 0) {
    sheet.appendRow(['quoteCode','quoteVersion','payloadJson','updatedAt']);
  }

  const quoteCode = String(payload.quoteCode || '').trim();
  const quoteVersion = String(payload.quoteVersion || '1').trim();
  if (!quoteCode) return;

  const payloadJson = JSON.stringify(payload);
  const now = nowPhilippineIso_();

  const lastRow = sheet.getLastRow();
  const lastCol = Math.max(1, sheet.getLastColumn());
  const values = sheet.getRange(1, 1, lastRow, lastCol).getValues();

  // Find matching row
  let matchRow = -1;
  for (let r = 1; r < values.length; r += 1) {
    const qc = String(values[r][0] || '').trim();
    const qv = String(values[r][1] || '').trim();
    if (qc === quoteCode && qv === quoteVersion) {
      matchRow = r + 1;
      break;
    }
  }

  if (matchRow > 0) {
    sheet.getRange(matchRow, 3).setValue(payloadJson);
    sheet.getRange(matchRow, 4).setValue(now);
  } else {
    sheet.appendRow([quoteCode, quoteVersion, payloadJson, now]);
  }
}

function findQuotePayload_(quoteCode, quoteVersion) {
  const ss = getSpreadsheet_();
  if (!ss) return null;

  const sheet = ss.getSheetByName('quotes');
  if (!sheet) return null;

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return null;

  const values = sheet.getRange(2, 1, lastRow - 1, 4).getValues();
  for (let i = 0; i < values.length; i += 1) {
    const qc = String(values[i][0] || '').trim();
    const qv = String(values[i][1] || '').trim();
    if (qc === String(quoteCode).trim() && qv === String(quoteVersion).trim()) {
      return String(values[i][2] || '').trim();
    }
  }
  return null;
}
