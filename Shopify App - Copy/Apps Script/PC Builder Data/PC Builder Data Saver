function nowPhilippineIso_() {
  const base = Utilities.formatDate(new Date(), PH_TIMEZONE, "yyyy-MM-dd'T'HH:mm:ss");
  return `${base}+08:00`;
}

function nowPhilippineDate_() {
  return Utilities.formatDate(new Date(), PH_TIMEZONE, 'yyyy-MM-dd');
}

function normalizeSourceTag_(value) {
  return String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9_-]+/g, '_')
    .replace(/^_+|_+$/g, '');
}

function isSourceEvent_(eventName) {
  const event = String(eventName || '').trim();
  return [
    'link_open',
    'pc_builder_open',
    'page_open',
    'cta_click'
  ].indexOf(event) >= 0;
}

