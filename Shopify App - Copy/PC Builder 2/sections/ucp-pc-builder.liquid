<script>
(function () {
  if (window.__UCP_PCB_RULES_BOOT__) return;
  window.__UCP_PCB_RULES_BOOT__ = true;

  var cfgEl = document.getElementById('ucp-pcb-config');
  var rulesEl = document.getElementById('ucp-pcb-bundle-rules');
  var promosEl = document.getElementById('ucp-pcb-promo-rules');
  var addonRulesEl = document.getElementById('ucp-pcb-addon-rules');

  var cfg = {};
  try { cfg = JSON.parse((cfgEl && cfgEl.textContent) ? cfgEl.textContent : '{}'); } catch (e) {}

  function withPage(baseUrl, page) {
    if (!baseUrl) return '';
    return baseUrl + (baseUrl.indexOf('?') > -1 ? '&' : '?') + 'page=' + page;
  }

  function fetchAllRules(baseUrl) {
    if (!baseUrl) return Promise.resolve(null);

    var out = [];
    var page = 1;
    var guard = 0;

    function step() {
      guard += 1;
      if (guard > 20) return Promise.resolve(out);

      return fetch(withPage(baseUrl, page), { credentials: 'same-origin' })
        .then(function (res) { if (!res.ok) throw new Error('rules fetch failed'); return res.json(); })
        .then(function (json) {
          var arr = (json && Array.isArray(json.rules)) ? json.rules : [];
          out = out.concat(arr);

          if (json && json.next_page) {
            page = json.next_page;
            return step();
          }
          return out;
        });
    }

    return step();
  }

  function fetchAllPromos(baseUrl) {
    if (!baseUrl) return Promise.resolve(null);

    var out = [];
    var page = 1;
    var guard = 0;

    function step() {
      guard += 1;
      if (guard > 20) return Promise.resolve(out);

      return fetch(withPage(baseUrl, page), { credentials: 'same-origin' })
        .then(function (res) { if (!res.ok) throw new Error('promos fetch failed'); return res.json(); })
        .then(function (json) {
          var arr = (json && Array.isArray(json.promos)) ? json.promos : [];
          out = out.concat(arr);

          if (json && json.next_page) {
            page = json.next_page;
            return step();
          }
          return out;
        });
    }

    return step();
  }

  function fetchAllAddonDiscounts(baseUrl) {
    if (!baseUrl) return Promise.resolve(null);

    var out = [];
    var page = 1;
    var guard = 0;

    function step() {
      guard += 1;
      if (guard > 20) return Promise.resolve(out);

      return fetch(withPage(baseUrl, page), { credentials: 'same-origin' })
        .then(function (res) { if (!res.ok) throw new Error('addon discounts fetch failed'); return res.json(); })
        .then(function (json) {
          var arr = (json && Array.isArray(json.addon_discounts)) ? json.addon_discounts : [];
          out = out.concat(arr);

          if (json && json.next_page) {
            page = json.next_page;
            return step();
          }
          return out;
        });
    }

    return step();
  }

  var rulesReady = fetchAllRules(cfg.bundle_rules_endpoint)
    .then(function (full) {
      if (rulesEl && full && full.length) {
        rulesEl.textContent = JSON.stringify(full);
      }
    })
    .catch(function () {
      // If the endpoint is missing or fails, we keep the fallback rules already embedded in the script tag (max 50).
    });

  var promosReady = fetchAllPromos(cfg.promo_rules_endpoint)
    .then(function (full) {
      if (promosEl && full && full.length) {
        promosEl.textContent = JSON.stringify(full);
      }
    })
    .catch(function () {
      // If the endpoint is missing or fails, we keep the fallback promos already embedded in the script tag (max 50).
    });

  var addonDiscountsReady = fetchAllAddonDiscounts(cfg.addon_discount_rules_endpoint)
    .then(function (full) {
      if (addonRulesEl && full && full.length) {
        addonRulesEl.textContent = JSON.stringify(full);
      }
    })
    .catch(function () {
      // If the endpoint is missing or fails, we keep the fallback add-on rules already embedded in the script tag (max 50).
    });

  Promise.all([rulesReady, promosReady, addonDiscountsReady])
    .finally(function () {
      function loadScript(src) {
        return new Promise(function (resolve, reject) {
          var s = document.createElement('script');
          s.src = src;
          s.defer = true;
          s.onload = resolve;
          s.onerror = reject;
          document.head.appendChild(s);
        });
      }

      var builderSrc = {{ 'ucp-pc-builder.js' | asset_url | json }};
      var buildLinkSrc = {{ 'ucp-pcb-build-link.js' | asset_url | json }};
      var requestQuoteSrc = {{ 'ucp-pcb-request-quote.js' | asset_url | json }};
      var onboardingSrc = {{ 'ucp-pcb-onboarding.js' | asset_url | json }};
      var approvalSrc = {{ 'ucp-pcb-approval.js' | asset_url | json }};
      var quoteLookupSrc = {{ 'ucp-pcb-quote-lookup.js' | asset_url | json }};

      loadScript(builderSrc)
        .then(function () { return loadScript(buildLinkSrc); })
        .then(function () { return loadScript(requestQuoteSrc); })
        .then(function () { return loadScript(onboardingSrc); })
        .then(function () { return loadScript(quoteLookupSrc); })
        .then(function () { return loadScript(approvalSrc); });
    });
})();
</script>

