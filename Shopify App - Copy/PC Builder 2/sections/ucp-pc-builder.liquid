  <div class="ucp-pcb__wrap">
    <aside class="ucp-pcb__summary">
      <div class="ucp-pcb__summaryCard">
        {%- comment -%}
          Mobile drawer close button.
          Hidden on desktop. Shown only when the drawer is open on mobile.
        {%- endcomment -%}
        <button class="ucp-pcb__drawerClose" type="button" id="ucp-pcb-summary-close" aria-label="Close build summary">
          Close
        </button>

        <div class="ucp-pcb__summaryTitle">Build summary</div>

        <div class="ucp-pcb__picked" id="ucp-pcb-picked"></div>

        {%- comment -%}
          MVP Performance Preview UI.
          JS will populate CPU and GPU context and FPS values.
          Data hooks:
          - [data-ucp-pcb-preset]
          - [data-ucp-pcb-fps]
        {%- endcomment -%}
        <div class="ucp-pcb__perfCard" id="ucp-pcb-perf" {% unless section.settings.pcb_perf_enabled %}hidden{% endunless %}>
          <div class="ucp-pcb__perfHead">
            <div class="ucp-pcb__perfTitle" id="ucp-pcb-perf-title">Performance preview</div>
            <div class="ucp-pcb__perfSub" id="ucp-pcb-perf-sub">Select a CPU and GPU</div>
          </div>

          <div class="ucp-pcb__perfControls">
            <div class="ucp-pcb__perfControl">
              <div class="ucp-pcb__perfLabel">Preset</div>
              <div class="ucp-pcb__perfPills" aria-label="Preset">
                <button type="button" class="ucp-pcb__pill" data-ucp-pcb-preset="low">LOW</button>
                <button type="button" class="ucp-pcb__pill" data-ucp-pcb-preset="med" data-active>MED</button>
                <button type="button" class="ucp-pcb__pill" data-ucp-pcb-preset="high">HIGH</button>
              </div>
            </div>
          </div>

          <div class="ucp-pcb__perfFps" aria-label="FPS">
            <div class="ucp-pcb__perfFpsCell">
              <small>1080P</small>
              <strong data-ucp-pcb-fps="1080p">N/A</strong>
            </div>
            <div class="ucp-pcb__perfFpsCell">
              <small>1440P</small>
              <strong data-ucp-pcb-fps="1440p">N/A</strong>
            </div>
            <div class="ucp-pcb__perfFpsCell">
              <small>4K</small>
              <strong data-ucp-pcb-fps="4k">N/A</strong>
            </div>
          </div>
        </div>

        <div class="ucp-pcb__summaryDockSource" data-ucp-pcb-dock-source>
        <div class="ucp-pcb__totals">
          <div class="ucp-pcb__totalsRow">
            <span>Subtotal</span>
            <strong id="ucp-pcb-subtotal-raw">₱0</strong>
          </div>
          <div class="ucp-pcb__totalsRow">
            <span>Bundle discount</span>
            <strong id="ucp-pcb-savings">₱0</strong>
          </div>
          <div class="ucp-pcb__totalsRow" data-ucp-pcb-promo-row hidden>
            <span id="ucp-pcb-promo-label">Promo discount</span>
            <strong id="ucp-pcb-promo-savings">₱0</strong>
