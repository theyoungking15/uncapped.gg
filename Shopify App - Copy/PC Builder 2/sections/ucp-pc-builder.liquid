{%- comment -%}
  File: sections/ucp-pc-builder.liquid

  Section: UCP PC Builder (Path 2)
  - Loads products per tab via collection JSON "view" endpoint
  - Avoids embedding huge JSON blobs in the page
  - Bundle rules JSON: fetch all rules via a page view endpoint to avoid the 50 metaobject cap

  Mobile UX notes:
  - On mobile, the summary is moved to the bottom (via CSS ordering).
  - A sticky bottom bar provides constant access to the build summary and actions.
  - The summary can be opened as a bottom drawer for easy access on long lists.
{%- endcomment -%}

{{ 'ucp-pc-builder.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign cpu_col      = section.settings.cpu_collection
  assign mobo_col     = section.settings.motherboards_collection
  assign gpu_col      = section.settings.gpu_collection
  assign ram_col      = section.settings.ram_collection
  assign ssd_col      = section.settings.ssd_collection
  assign case_col     = section.settings.case_collection
  assign psu_col      = section.settings.psu_collection
  assign cooler_col   = section.settings.cooler_collection
  assign casefans_col = section.settings.case_fans_collection
  assign other_col    = section.settings.ups_collection

  assign default_tab = section.settings.default_tab | default: 'processor'

  capture ep_cpu
    if cpu_col != blank
      echo cpu_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_mobo
    if mobo_col != blank
      echo mobo_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_gpu
    if gpu_col != blank
      echo gpu_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_ram
    if ram_col != blank
      echo ram_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_ssd
    if ssd_col != blank
      echo ssd_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_case
    if case_col != blank
      echo case_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_psu
    if psu_col != blank
      echo psu_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_cooler
    if cooler_col != blank
      echo cooler_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_casefans
    if casefans_col != blank
      echo casefans_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  capture ep_other
    if other_col != blank
      echo other_col.url | append: '?view=ucp-pc-builder-json'
    else
      echo ''
    endif
  endcapture

  comment
    Brand logo source (priority order):
    1) metaobject: brand.uncapped
    2) Shopify brand logo
    3) theme setting logo
  endcomment

  assign brand_mo = shop.metaobjects.brand['uncapped']
  assign brand_logo_media = blank

  if brand_mo != blank
    if brand_mo.logo != blank
      assign brand_logo_media = brand_mo.logo.value
    elsif brand_mo.image != blank
      assign brand_logo_media = brand_mo.image.value
    elsif brand_mo.brand_logo != blank
      assign brand_logo_media = brand_mo.brand_logo.value
    endif
  endif

  capture brand_logo_url
    if brand_logo_media != blank
      echo brand_logo_media | image_url: width: 240
    elsif shop.brand.logo != blank
      echo shop.brand.logo | image_url: width: 240
    elsif settings.logo != blank
      echo settings.logo | image_url: width: 240
    else
      echo ''
    endif
  endcapture

  comment
    Bundle rules metaobject fallback (still capped at 50 when looping values).
    We keep this only as a fallback if the JSON endpoint fails.
  endcomment

  assign rule_mo = shop.metaobjects['cpu_motherboard_bundle']
  assign rules = blank
  if rule_mo and rule_mo.values
    assign rules = rule_mo.values
  endif

  assign bundle_rules_endpoint = '/pages/ucp-pcb-bundle-rules?view=ucp-pcb-bundle-rules-json'

  assign promo_mo = shop.metaobjects['pc_builder_promo']
  assign promos = blank
  if promo_mo and promo_mo.values
    assign promos = promo_mo.values
  endif

  assign promo_rules_endpoint = '/pages/ucp-pcb-promos?view=ucp-pcb-promos-json'

  assign addon_mo = shop.metaobjects['pc_builder_addon_discount']
  assign addon_promos = blank
  if addon_mo and addon_mo.values
    assign addon_promos = addon_mo.values
  endif

  assign addon_discount_rules_endpoint = '/pages/ucp-pcb-addon-discounts?view=ucp-pcb-addon-discounts-json'

  assign onboard_b1 = section.settings.onboarding_bullet_1 | strip
  assign onboard_b2 = section.settings.onboarding_bullet_2 | strip
  assign onboard_b3 = section.settings.onboarding_bullet_3 | strip

  assign onboard_gif_src = blank
  if section.settings.onboarding_gif_image != blank
    assign onboard_gif_src = section.settings.onboarding_gif_image | image_url: width: 720
  elsif section.settings.onboarding_gif_url != blank
    assign onboard_gif_src = section.settings.onboarding_gif_url | strip
  endif
-%}

<section class="ucp-pcb" data-ucp-pcb data-default-tab="{{ default_tab | escape }}">
  <script type="application/json" id="ucp-pcb-config">
  {
    "brand_logo": {{ brand_logo_url | strip | json }},
    "quote_screenshot_mode": {{ section.settings.quote_screenshot_mode | json }},
    "quote_screenshot_mode_mobile": {{ section.settings.quote_screenshot_mode_mobile | default: 'same_as_desktop' | json }},
    "quote_font_preset": {{ section.settings.quote_font_preset | default: 'inter_roboto' | json }},

    "bundle_rules_endpoint": {{ bundle_rules_endpoint | json }},
    "promo_rules_endpoint": {{ promo_rules_endpoint | json }},
    "addon_discount_rules_endpoint": {{ addon_discount_rules_endpoint | json }},

    "messenger_url": {{ 'https://www.facebook.com/UncappedPC' | json }},
    "apps_script_webapp_url": {{ 'https://script.google.com/macros/s/AKfycbysHP_LKSCNjTczUQZr0OT5pMY37htXnWk_MowJ9mRTqTeCA9Gy49JprHDbkWOCYM-2/exec' | json }},
    "quote_contact_endpoint": "/contact",
    "my_builds_proxy_base_path": {{ section.settings.my_builds_proxy_base_path | json }},
    "my_builds_page_url": {{ section.settings.my_builds_page_url | json }},
    "loading_modals": {
      "promo": {{ section.settings.promo_loading_modal_enabled | json }},
      "quote": {{ section.settings.quote_loading_modal_enabled | json }},
      "build": true,
      "approval": {{ section.settings.approval_loading_modal_enabled | json }}
    },
    "customer": {% if customer %}
      {
        "id": {{ customer.id | json }},
        "email": {{ customer.email | json }},
        "first_name": {{ customer.first_name | json }},
        "last_name": {{ customer.last_name | json }}
      }
    {% else %}
      null
    {% endif %},

    "payment": {
      "enabled": {{ section.settings.approval_payment_enabled | json }},
      "proof_mode": {{ section.settings.payment_proof_mode | json }},
      "messenger_username": {{ section.settings.payment_messenger_username | json }},
      "facebook_page_url": {{ section.settings.payment_facebook_page_url | json }},
      "proof_text": {{ section.settings.payment_proof_text | json }},
      "methods": [
        {%- assign pm_first = true -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'payment_method' -%}
            {%- unless pm_first -%},{%- endunless -%}
            {
              "id": {{ block.settings.method_id | strip | json }},
              "label": {{ block.settings.method_label | strip | json }},
              "logo": {%- if block.settings.method_logo != blank -%}{{ block.settings.method_logo | image_url: width: 200 | json }}{%- else -%}null{%- endif -%},
              "qr": {%- if block.settings.method_qr != blank -%}{{ block.settings.method_qr | image_url: width: 360 | json }}{%- else -%}null{%- endif -%},
              "account_name": {{ block.settings.account_name | strip | json }},
              "account_number": {{ block.settings.account_number | strip | json }}
            }
            {%- assign pm_first = false -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    },

    "storefront_api_version": "2024-10",
    "storefront_token": "",

    "perf_preview_endpoint": "",
    "perf_storefront_token": "",
    "perf_metaobject_type": "benchmark_entry",
    "perf_preview_enabled": {{ section.settings.pcb_perf_enabled | json }},

    "payment_mobile_qr_download_enabled": {{ section.settings.payment_mobile_qr_download_enabled | json }},
    "payment_mobile_pdf_mode": {{ section.settings.payment_mobile_pdf_mode | json }},
    "approval_strip_param_on_close": {{ section.settings.approval_strip_param_on_close | json }},
    "approval_reopen_button_enabled": {{ section.settings.approval_reopen_button_enabled | json }},
    "onboarding_enabled": {{ section.settings.onboarding_enabled | json }},
    "onboarding_title": {{ section.settings.onboarding_title | json }},
    "onboarding_bullets": [
      {%- if onboard_b1 != blank -%}{{ onboard_b1 | json }}{%- endif -%}
      {%- if onboard_b1 != blank and onboard_b2 != blank -%},{{ onboard_b2 | json }}{%- elsif onboard_b1 == blank and onboard_b2 != blank -%}{{ onboard_b2 | json }}{%- endif -%}
      {%- if onboard_b3 != blank -%}{%- if onboard_b1 != blank or onboard_b2 != blank -%},{{ onboard_b3 | json }}{%- else -%}{{ onboard_b3 | json }}{%- endif -%}{%- endif -%}
    ],
    "onboarding_show_try_share": {{ section.settings.onboarding_show_try_share | json }},
    "onboarding_got_it_label": {{ section.settings.onboarding_got_it_label | json }},
    "onboarding_try_share_label": {{ section.settings.onboarding_try_share_label | json }},
    "onboarding_gif_enabled": {{ section.settings.onboarding_gif_enabled | json }},
    "onboarding_gif_mode": {{ section.settings.onboarding_gif_mode | json }},
    "onboarding_gif_src": {{ onboard_gif_src | json }},
    "onboarding_view_demo_label": {{ section.settings.onboarding_view_demo_label | json }},
    "promo_discovery_modal_enabled": {{ section.settings.promo_discovery_modal_enabled | json }},
    "promo_discovery_visibility_mode": {{ section.settings.promo_discovery_visibility_mode | default: 'cooldown' | json }},
    "promo_discovery_cooldown_days": {{ section.settings.promo_discovery_cooldown_days | default: 7 | json }},
    "hints_enabled": {{ section.settings.hints_enabled | json }},
    "hint_share_text": {{ section.settings.hint_share_text | json }},
    "hint_quote_text": {{ section.settings.hint_quote_text | json }},
    "availability_filter_enabled": {{ section.settings.availability_filter_enabled | json }},
    "availability_filter_default_on": {{ section.settings.availability_filter_default_on | json }},
    "payment_methods": [
      {%- assign pm_mobile_first = true -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'payment_method' -%}
          {%- unless pm_mobile_first -%},{%- endunless -%}
          {
            "id": {{ block.settings.method_id | strip | json }},
            "name": {{ block.settings.method_label | strip | json }},
            "logo": {%- if block.settings.method_logo != blank -%}{{ block.settings.method_logo | image_url: width: 200 | json }}{%- else -%}null{%- endif -%},
            "qr": {%- if block.settings.method_qr != blank -%}{{ block.settings.method_qr | image_url: width: 360 | json }}{%- else -%}null{%- endif -%},
            "account_name": {{ block.settings.account_name | strip | json }},
            "account_number": {{ block.settings.account_number | strip | json }}
          }
          {%- assign pm_mobile_first = false -%}
        {%- endif -%}
      {%- endfor -%}
    ],

    "endpoints": {
      "processor": {{ ep_cpu | strip | json }},
      "motherboard": {{ ep_mobo | strip | json }},
      "gpu": {{ ep_gpu | strip | json }},
      "memory": {{ ep_ram | strip | json }},
      "ssd": {{ ep_ssd | strip | json }},
      "case": {{ ep_case | strip | json }},
      "powersupply": {{ ep_psu | strip | json }},
      "cpucooler": {{ ep_cooler | strip | json }},
      "casefans": {{ ep_casefans | strip | json }},
      "other": {{ ep_other | strip | json }}
    }
  }
  </script>

  <script type="application/json" id="ucp-pcb-bundle-rules">
  [
    {%- assign first = true -%}
    {%- if rules != blank -%}
      {%- for r in rules -%}
        {%- assign is_active = r.is_active.value -%}
        {%- if is_active -%}
          {%- assign cpu_p = r.cpu_product.value -%}
          {%- assign cpu_v = r.cpu_variant.value -%}
          {%- assign mobo_p = r.motherboard_product.value -%}
          {%- assign mobo_v = r.motherboard_variant.value -%}
          {%- if mobo_v == blank -%}
            {%- assign mobo_v = r.motherboard_varinat.value -%}
          {%- endif -%}

          {%- if cpu_p != blank and mobo_p != blank -%}
            {%- assign cpu_handle = cpu_p.metafields.custom.bench_cpu_handle | default: cpu_p.handle | strip | downcase -%}
            {%- assign mobo_handle = mobo_p.metafields.custom.bench_motherboard_handle | default: mobo_p.handle | strip | downcase -%}
            {%- assign rule_handle = '' -%}
            {%- if r.system and r.system.handle -%}
              {%- assign rule_handle = r.system.handle | strip | downcase -%}
            {%- endif -%}

            {%- unless first -%},{%- endunless -%}
            {
              "handle": {{ rule_handle | json }},
              "rule_label": {{ r.rule_label.value | default: '' | json }},
              "sort_order": {{ r.sort_order.value | default: 0 | json }},
              "discount_amount": {{ r.discount_amount.value | default: 0 | json }},

              "cpu_handle": {{ cpu_handle | json }},
              "mobo_handle": {{ mobo_handle | json }},

              "cpu_product_id": {{ cpu_p.id | json }},
              "cpu_variant_id": {% if cpu_v != blank %}{{ cpu_v.id | json }}{% else %}null{% endif %},
              "mobo_product_id": {{ mobo_p.id | json }},
              "mobo_variant_id": {% if mobo_v != blank %}{{ mobo_v.id | json }}{% else %}null{% endif %}
            }
            {%- assign first = false -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  ]
  </script>

  <script type="application/json" id="ucp-pcb-promo-rules">
  [
    {%- assign promo_first = true -%}
    {%- if promos != blank -%}
      {%- for p in promos -%}
        {%- assign is_active = p.is_active.value -%}
        {%- if is_active -%}
          {%- assign promo_handle = '' -%}
          {%- if p.system and p.system.handle -%}
            {%- assign promo_handle = p.system.handle | strip | downcase -%}
          {%- endif -%}
          {%- assign promo_image = p.image.value -%}

          {%- unless promo_first -%},{%- endunless -%}
          {
            "handle": {{ promo_handle | json }},
            "promo_label": {{ p.promo_label.value | default: '' | json }},
            "is_active": {{ p.is_active.value | default: false | json }},
            "discount_amount": {{ p.discount_amount.value | default: 0 | json }},
            "stack_with_bundle_discount": {{ p.stack_with_bundle_discount.value | default: false | json }},
            "required_components": {%- if p.required_components.value != blank -%}{{ p.required_components.value | json }}{%- else -%}[]{%- endif -%},
            "badge_label": {{ p.badge_label.value | default: '' | json }},
            "description": {{ p.description.value | default: '' | json }},
            "terms": {{ p.terms.value | default: '' | json }},
            "starts_at": {{ p.starts_at.value | default: '' | json }},
            "ends_at": {{ p.ends_at.value | default: '' | json }},
            "priority": {{ p.priority.value | default: 0 | json }},
            "public_visibility": {{ p.public_visibility.value | default: false | json }},
            "image_url": {%- if promo_image != blank -%}{{ promo_image | image_url: width: 720 | json }}{%- else -%}""{%- endif -%}
          }
          {%- assign promo_first = false -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  ]
  </script>

  <script type="application/json" id="ucp-pcb-addon-rules">
  [
    {%- assign addon_first = true -%}
    {%- if addon_promos != blank -%}
      {%- for p in addon_promos -%}
        {%- assign is_active = p.is_active.value -%}
        {%- if is_active -%}
          {%- assign addon_handle = '' -%}
          {%- if p.system and p.system.handle -%}
            {%- assign addon_handle = p.system.handle | strip | downcase -%}
          {%- endif -%}

          {%- unless addon_first -%},{%- endunless -%}
          {
            "handle": {{ addon_handle | json }},
            "promo_label": {{ p.promo_label.value | default: '' | json }},
            "is_active": {{ p.is_active.value | default: false | json }},
            "unlock_on_bundle_discount": {{ p.unlock_on_bundle_discount.value | default: false | json }},
            "unlock_on_any_primary_promo": {{ p.unlock_on_any_primary_promo.value | default: false | json }},
            "qualifying_promo_handles": {%- if p.qualifying_promo_handles.value != blank -%}{{ p.qualifying_promo_handles.value | json }}{%- else -%}[]{%- endif -%},
            "bulk_unlock_enabled": {{ p.bulk_unlock_enabled.value | default: false | json }},
            "bulk_qualifying_tabs": {%- if p.bulk_qualifying_tabs.value != blank -%}{{ p.bulk_qualifying_tabs.value | json }}{%- else -%}[]{%- endif -%},
            "bulk_min_qualifying_tabs": {{ p.bulk_min_qualifying_tabs.value | default: 0 | json }},
            "stack_with_bundle_discount": {{ p.stack_with_bundle_discount.value | default: true | json }},
            "stack_with_primary_promo": {{ p.stack_with_primary_promo.value | default: true | json }},
            "discounted_targets": {%- if p.discounted_targets.value != blank -%}{{ p.discounted_targets.value | json }}{%- else -%}[]{%- endif -%},
            "badge_label": {{ p.badge_label.value | default: '' | json }},
            "description": {{ p.description.value | default: '' | json }},
            "starts_at": {{ p.starts_at.value | default: '' | json }},
            "ends_at": {{ p.ends_at.value | default: '' | json }},
            "priority": {{ p.priority.value | default: 0 | json }},
            "internal_note": {{ p.internal_note.value | default: '' | json }}
          }
          {%- assign addon_first = false -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  ]
  </script>

